@{
    ViewData["Title"] = "Return & Refund Management";
}

<style>
    .refund-search { max-width: 320px; }
    .status-badge { font-size: .72rem; }
</style>

<div class="d-flex align-items-center gap-2 mt-4 mb-3">
    <a asp-controller="StaffDashboard" asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Dashboard
    </a>
    <h4 class="mb-0 fw-bold"><i class="bi bi-arrow-repeat me-2" style="color:#2d7a4f;"></i>Return & Refund</h4>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success d-flex align-items-center gap-2 py-2" role="alert">
        <i class="bi bi-check-circle-fill flex-shrink-0"></i>
        <span class="small">@TempData["SuccessMessage"]</span>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger d-flex align-items-center gap-2 py-2" role="alert">
        <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
        <span class="small">@TempData["ErrorMessage"]</span>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h6 class="fw-bold mb-0"><i class="bi bi-cart3 me-2" style="color:#2d7a4f;"></i>Orders</h6>
        <div class="input-group refund-search">
            <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
            <input type="text" id="orderSearch" class="form-control form-control-sm" placeholder="Search by order ID, customer..." autocomplete="off" />
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="ordersTable">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">Order ID</th>
                        <th>Customer</th>
                        <th>Items</th>
                        <th>Order Date</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.Orders != null && ((IEnumerable<dynamic>)ViewBag.Orders).Any())
                    {
                        foreach (var order in ViewBag.Orders)
                        {
                            var statusClass = ((string)order.Status) switch
                            {
                                "PENDING" => "bg-warning text-dark",
                                "CONFIRMED" => "bg-info text-dark",
                                "PROCESSING" => "bg-primary",
                                "DISPATCHED" => "bg-primary",
                                "DELIVERED" => "bg-success",
                                "CANCELLED" => "bg-secondary",
                                _ => "bg-secondary"
                            };
                            <tr class="order-row"
                                data-orderid="@order.OrderId"
                                data-customer="@order.CustomerName.ToString().ToLower()">
                                <td class="ps-3 fw-semibold small">#@order.OrderId</td>
                                <td class="small">@order.CustomerName</td>
                                <td class="small text-muted">@order.ItemCount item(s)</td>
                                <td class="small text-muted">@order.OrderDate.ToString("d MMM yyyy")</td>
                                <td class="small fw-semibold">$@order.Total.ToString("0.00")</td>
                                <td><span class="badge @statusClass rounded-pill status-badge">@order.Status</span></td>
                                <td>
                                    @if (order.HasRefund)
                                    {
                                        <span class="badge bg-secondary rounded-pill status-badge">Return Filed</span>
                                    }
                                    else
                                    {
                                        <a asp-action="InitiateReturn" asp-route-orderId="@order.OrderId"
                                           class="btn btn-outline-warning btn-sm py-0">
                                            <i class="bi bi-arrow-return-left me-1"></i>Initiate Return
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4 small">
                            <i class="bi bi-inbox fs-4 d-block mb-1"></i>No orders found.
                        </td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div id="noResults" class="text-center text-muted py-4 d-none">
        <i class="bi bi-search fs-3 d-block mb-2"></i>No orders match your search.
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('orderSearch')?.addEventListener('input', function () {
        const query = this.value.toLowerCase().trim();
        const rows = document.querySelectorAll('.order-row');
        let visible = 0;
        rows.forEach(row => {
            const orderId = row.dataset.orderid;
            const customer = row.dataset.customer;
            const match = !query || orderId.includes(query) || customer.includes(query);
            row.style.display = match ? '' : 'none';
            if (match) visible++;
        });
        document.getElementById('noResults')?.classList.toggle('d-none', visible > 0);
    });
</script>
}
