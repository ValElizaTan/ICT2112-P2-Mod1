@{
    ViewData["Title"] = "Initiate Return";
    int orderId = ViewBag.OrderId;
    int customerId = ViewBag.CustomerId;
    string customerName = ViewBag.CustomerName;
    DateTime orderDate = ViewBag.OrderDate;
    decimal total = ViewBag.Total;
    int itemCount = ViewBag.ItemCount;
    string status = ViewBag.Status;
}

<div class="d-flex align-items-center gap-2 mt-4 mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
    <h4 class="mb-0 fw-bold"><i class="bi bi-arrow-return-left me-2" style="color:#2d7a4f;"></i>Initiate Return</h4>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger d-flex align-items-center gap-2 py-2" role="alert">
        <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
        <span class="small">@TempData["ErrorMessage"]</span>
    </div>
}

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-bottom py-3">
                <h6 class="fw-bold mb-0"><i class="bi bi-receipt me-2" style="color:#2d7a4f;"></i>Order Details</h6>
            </div>
            <div class="card-body">
                <dl class="row mb-0 small">
                    <dt class="col-5 text-muted fw-normal">Order ID</dt>
                    <dd class="col-7 fw-semibold mb-2">#@orderId</dd>
                    <dt class="col-5 text-muted fw-normal">Customer</dt>
                    <dd class="col-7 fw-semibold mb-2">@customerName</dd>
                    <dt class="col-5 text-muted fw-normal">Order Date</dt>
                    <dd class="col-7 mb-2">@orderDate.ToString("d MMM yyyy")</dd>
                    <dt class="col-5 text-muted fw-normal">Items</dt>
                    <dd class="col-7 mb-2">@itemCount item(s)</dd>
                    <dt class="col-5 text-muted fw-normal">Total</dt>
                    <dd class="col-7 fw-bold mb-2" style="color:#2d7a4f;">$@total.ToString("0.00")</dd>
                    <dt class="col-5 text-muted fw-normal">Current Status</dt>
                    <dd class="col-7 mb-0"><span class="badge bg-primary rounded-pill" style="font-size:.72rem;">@status</span></dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-bottom py-3">
                <h6 class="fw-bold mb-0"><i class="bi bi-cash-stack me-2" style="color:#2d7a4f;"></i>Return & Refund Details</h6>
            </div>
            <div class="card-body">
                <form asp-action="ConfirmReturn" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderId" value="@orderId" />
                    <input type="hidden" name="customerId" value="@customerId" />

                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Return Method</label>
                        <select name="returnMethod" class="form-select" required>
                            <option value="In-Store">In-Store Drop-off</option>
                            <option value="Courier">Courier Pickup</option>
                            <option value="Self-Ship">Self-Ship</option>
                        </select>
                    </div>

                    <div class="alert alert-info py-2 small mb-3">
                        <i class="bi bi-info-circle me-1"></i>
                        This will create a return request and trigger Module 2's return processing pipeline (inspection, cleaning, restocking).
                        The deposit refund will be processed after inspection is complete.
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning fw-semibold">
                            <i class="bi bi-arrow-return-left me-1"></i>Confirm Return & Refund
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
