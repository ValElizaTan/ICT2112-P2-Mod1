@* Shared popup content. *@
<div aria-live="polite" aria-atomic="true" class="position-fixed top-0 end-0 p-3" style="z-index:1100; min-width:280px;">
  <div id="globalNotificationToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
    <div class="toast-header">
      <strong class="me-auto">Notification</strong>
      <small id="globalNotificationTime">just now</small>
      <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
    </div>
    <div class="toast-body" id="globalNotificationToastBody"></div>
    <div class="toast-footer d-flex justify-content-end p-2">
      <button id="ackNotificationBtn" type="button" class="btn btn-sm btn-primary me-2">Acknowledge</button>
      <button id="dismissNotificationBtn" type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="toast">Dismiss</button>
    </div>
  </div>
</div>