    @inject IHttpContextAccessor HttpContextAccessor
    @{
        var _navRole = HttpContextAccessor.HttpContext!.Session.GetString("UserRole") ?? "";
        bool _isStaff = _navRole.Equals("STAFF", StringComparison.OrdinalIgnoreCase)
                     || _navRole.Equals("ADMIN", StringComparison.OrdinalIgnoreCase);
    }

        <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
            <div class="container">
    
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <i class="bi bi-box-seam-fill me-2" style="color: #2d7a4f;"></i>Pro Rentals
            </a>

            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#mainNav"
                    aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                    @* Module 1 — Order Processing *@
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-cart3 me-1"></i>Order Processing
                        </a>
                        <ul class="dropdown-menu">
                            <li><h6 class="dropdown-header text-uppercase" style="color: #2d7a4f; font-size: 0.7rem;">Team 4</h6></li>
                            <li><a class="dropdown-item" asp-controller="OrderManagement" asp-action="Index"><i class="bi bi-clipboard-check me-2" style="color: #2d7a4f;"></i>Manage Orders</a></li>
                            @if (!_isStaff)
                            {
                                <li><a class="dropdown-item" asp-controller="OrderTracking" asp-action="CustomerOrderTracking"><i class="bi bi-search me-2" style="color: #2d7a4f;"></i>Track Order</a></li>
                                <li><a class="dropdown-item" asp-controller="CustomerDashboard" asp-action="Returns" asp-route-customerId="1"><i class="bi bi-arrow-return-left me-2" style="color: #2d7a4f;"></i>Handle Returns</a></li>
                                <li><a class="dropdown-item" asp-controller="CustomerDashboard" asp-action="Refunds" asp-route-customerId="1"><i class="bi bi-cash-coin me-2" style="color: #2d7a4f;"></i>Deposit Refunds</a></li>
                            }
                            @if (_isStaff)
                            {
                                <li><a class="dropdown-item" asp-controller="Shipping" asp-action="DisplayShipmentList"><i class="bi bi-truck me-2" style="color: #2d7a4f;"></i>Manage Dispatch</a></li>
                                <li><a class="dropdown-item" asp-controller="NotificationDisplay" asp-action="Index" asp-route-userId="1"><i class="bi bi-bell me-2" style="color: #2d7a4f;"></i>Order Notifications</a></li>
                            }
                            <li><h6 class="dropdown-header text-uppercase" style="color: #2d7a4f; font-size: 0.7rem;">Team 6</h6></li>
                            @if (_isStaff)
                            {
                                <li><a class="dropdown-item" asp-controller="Cart" asp-action="Index"><i class="bi bi-cart me-2" style="color: #2d7a4f;"></i>View Cart</a></li>
                            }
                            <li><a class="dropdown-item" asp-controller="Catalogue" asp-action="Index"><i class="bi bi-plus-circle me-2" style="color: #2d7a4f;"></i>Place Order</a></li>
                            <li><a class="dropdown-item" asp-controller="Module1" asp-action="Orders" asp-route-customerId="@Context.Session.GetInt32("CustomerId")"><i class="bi bi-list me-2" style="color: #2d7a4f;"></i>My Orders</a></li>
                        </ul>
                    </li>

                    @* Module 2 — Inventory Management *@
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-boxes me-1"></i>Inventory Management
                        </a>
                        <ul class="dropdown-menu">
                            <li><h6 class="dropdown-header text-uppercase" style="color: #0d6efd; font-size: 0.7rem;">Module 2</h6></li>
                            <li><a class="dropdown-item" href="/Catalogue"><i class="bi bi-grid me-2" style="color: #0d6efd;"></i>Product Catalogue</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-box-seam me-2" style="color: #0d6efd;"></i>Stock Management</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-arrow-repeat me-2" style="color: #0d6efd;"></i>Return Processing Pipeline</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-building-check me-2" style="color: #0d6efd;"></i>Trusted Supplier Registry</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-bar-chart-line me-2" style="color: #0d6efd;"></i>Analytics &amp; Reports</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-tag me-2" style="color: #0d6efd;"></i>Product Clearance</a></li>
                        </ul>
                    </li>

                    @* Module 3 — Carbon Footprint *@
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-leaf me-1"></i>Carbon Footprint
                        </a>
                        <ul class="dropdown-menu">
                            <li><h6 class="dropdown-header text-uppercase" style="color: #0a9396; font-size: 0.7rem;">Module 3</h6></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-calculator me-2" style="color: #0a9396;"></i>Product Carbon Calculator</a></li>
                            @if (_isStaff)
                            {
                                <li><a class="dropdown-item" href="#"><i class="bi bi-truck-flatbed me-2" style="color: #0a9396;"></i>Shipment Carbon Tracker</a></li>
                            }
                            <li><a class="dropdown-item" href="#"><i class="bi bi-signpost-2 me-2" style="color: #0a9396;"></i>Route Distance Determination</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-building me-2" style="color: #0a9396;"></i>Warehouse Storage Emissions</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-recycle me-2" style="color: #0a9396;"></i>Return Process Carbon Lifecycle</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-collection me-2" style="color: #0a9396;"></i>Batch Delivery Consolidation</a></li>
                        </ul>
                    </li>

                </ul>

                @* Auth buttons *@
                <div class="d-flex gap-2">
                    @if (HttpContextAccessor.HttpContext!.Session.GetInt32("SessionId") != null)
                    {
                        var navRole = HttpContextAccessor.HttpContext!.Session.GetString("UserRole") ?? "";
                        var navCustomerId = HttpContextAccessor.HttpContext!.Session.GetInt32("CustomerId");

                        <span class="navbar-text text-white-50 small me-1">
                            <i class="bi bi-person-circle me-1"></i>
                            @if (navRole.Equals("CUSTOMER", StringComparison.OrdinalIgnoreCase) && navCustomerId.HasValue)
                            {
                                <a asp-controller="CustomerProfile" asp-action="Index" asp-route-customerId="@navCustomerId.Value"
                                   class="text-white-50 text-decoration-none">@HttpContextAccessor.HttpContext!.Session.GetString("UserName")</a>
                            }
                            else if (navRole.Equals("STAFF", StringComparison.OrdinalIgnoreCase) || navRole.Equals("ADMIN", StringComparison.OrdinalIgnoreCase))
                            {
                                <a asp-controller="StaffDashboard" asp-action="Index"
                                   class="text-white-50 text-decoration-none">@HttpContextAccessor.HttpContext!.Session.GetString("UserName")</a>
                            }
                            else
                            {
                                @HttpContextAccessor.HttpContext!.Session.GetString("UserName")
                            }
                            <span class="badge bg-secondary ms-1">@HttpContextAccessor.HttpContext!.Session.GetString("UserRole")</span>
                            </span>
                        <form asp-controller="Module1" asp-action="Logout" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-box-arrow-right me-1"></i>Logout
                                </button>
                        </form>
                    }
                    else
                    {
                        <a href="/Module1/Login" class="btn btn-outline-light btn-sm">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Login
                        </a>
                        <a href="/Module1/Signup" class="btn btn-primary btn-sm">
                        <i class="bi bi-person-plus me-1"></i>Register
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>
