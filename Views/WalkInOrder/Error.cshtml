@{
    ViewData["Title"] = "Order Error";
    var errorMessage = ViewData["ErrorMessage"] as string ?? "An unexpected error occurred.";
}

<div class="row justify-content-center py-5">
    <div class="col-12 col-md-8 col-lg-5 text-center">
        <i class="bi bi-exclamation-triangle fs-1 text-danger d-block mb-3"></i>
        <h3 class="fw-semibold mb-3">Something went wrong</h3>
        <div class="alert alert-danger text-start">
            <i class="bi bi-info-circle me-2"></i>@errorMessage
        </div>
        <a asp-action="Index" class="btn btn-outline-primary mt-2">
            <i class="bi bi-arrow-left me-1"></i>Start Over
        </a>
    </div>
</div>
