@using ProRental.Domain.Entities
@using ProRental.Domain.Enums

@{
    ViewData["Title"] = "Staff Order Tracking";

    var orders = ViewBag.Orders as List<Order> ?? new List<Order>();
    var bulkResults = ViewBag.BulkResults as List<string> ?? new List<string>();

    var pendingOrders = orders.Where(o => o.GetStatus() == OrderStatus.PENDING).ToList();
    var dispatchedOrders = orders.Where(o => o.GetStatus() == OrderStatus.DISPATCHED).ToList();
    var readyOrders = orders.Where(o => o.GetStatus() == OrderStatus.READY_FOR_DISPATCH).ToList();

    var pendingCount = pendingOrders.Count;
    var dispatchedCount = dispatchedOrders.Count;
    var readyCount = readyOrders.Count;

    var allStatuses = new List<OrderStatus>
    {
        OrderStatus.PENDING,
        OrderStatus.CONFIRMED,
        OrderStatus.PROCESSING,
        OrderStatus.READY_FOR_DISPATCH,
        OrderStatus.DISPATCHED,
        OrderStatus.DELIVERED,
        OrderStatus.CANCELLED
    };

    var selectedStatusText = ViewBag.SelectedStatus as string ?? "";
    OrderStatus parsedStatus;
    var hasSelectedStatus = Enum.TryParse<OrderStatus>(selectedStatusText, out parsedStatus);

    var searchedOrderId = ViewBag.SearchedOrderId as int?;

    var displayOrders = orders.AsEnumerable();

    var selectedTimelineOrderId = ViewBag.SelectedTimelineOrderId as int?;
    
    var selectedTimeline = ViewBag.SelectedTimeline as List<Orderstatushistory> ?? new List<Orderstatushistory>();

    var selectedOrder = selectedTimelineOrderId.HasValue
    ? orders.FirstOrDefault(o => o.GetOrderId() == selectedTimelineOrderId.Value)
    : null;

    if (searchedOrderId.HasValue)
    {
        displayOrders = displayOrders.Where(o => o.GetOrderId() == searchedOrderId.Value);
    }

    if (hasSelectedStatus)
    {
        displayOrders = displayOrders.Where(o => o.GetStatus() == parsedStatus);
    }

    displayOrders = displayOrders.OrderByDescending(o => o.GetOrderDate());
}

@functions {
    public string GetBadgeClass(OrderStatus? status)
    {
        return status switch
        {
            OrderStatus.PENDING => "badge-pending",
            OrderStatus.CONFIRMED => "badge-confirmed",
            OrderStatus.PROCESSING => "badge-processing",
            OrderStatus.READY_FOR_DISPATCH => "badge-ready",
            OrderStatus.DISPATCHED => "badge-dispatched",
            OrderStatus.DELIVERED => "badge-delivered",
            OrderStatus.CANCELLED => "badge-cancelled",
            _ => "bg-secondary text-white"
        };
    }

    public bool IsStatusReached(OrderStatus step, OrderStatus? current)
    {
        if (!current.HasValue) return false;

        if (current.Value == OrderStatus.CANCELLED)
        {
            return step == OrderStatus.CANCELLED;
        }

        var sequence = new List<OrderStatus>
        {
            OrderStatus.PENDING,
            OrderStatus.CONFIRMED,
            OrderStatus.PROCESSING,
            OrderStatus.READY_FOR_DISPATCH,
            OrderStatus.DISPATCHED,
            OrderStatus.DELIVERED
        };

        var stepIndex = sequence.IndexOf(step);
        var currentIndex = sequence.IndexOf(current.Value);

        if (step == OrderStatus.CANCELLED) return false;
        if (stepIndex < 0 || currentIndex < 0) return false;

        return stepIndex <= currentIndex;
    }

    public string GetStepClass(OrderStatus step, OrderStatus? current)
    {
        if (!current.HasValue) return "step step-muted";

        if (current.Value == OrderStatus.CANCELLED)
        {
            return step == OrderStatus.CANCELLED
                ? "step step-active step-cancelled"
                : "step step-muted";
        }

        return IsStatusReached(step, current) ? "step step-active" : "step step-muted";
    }
}

<style>
    .stat-card { border-left: 4px solid transparent; transition: box-shadow .2s; }
    .stat-card:hover { box-shadow: 0 .5rem 1.25rem rgba(0,0,0,.12) !important; }
    .stat-card-green  { border-left-color: #2d7a4f; }
    .stat-card-blue   { border-left-color: #0d6efd; }
    .stat-card-orange { border-left-color: #fd7e14; }

    .tracking-card,
    .section-card {
        border-radius: 18px;
        box-shadow: 0 .125rem .5rem rgba(0,0,0,.08);
        border: 0;
    }

    .table-hover tbody tr:hover { background: rgba(45,122,79,.06); }

    .badge-pending { background: #fff3cd; color: #856404; }
    .badge-confirmed { background: #cff4fc; color: #055160; }
    .badge-processing { background: #ffe5b4; color: #7a4b00; }
    .badge-ready { background: #d1e7dd; color: #0a3622; }
    .badge-dispatched { background: #cfe2ff; color: #084298; }
    .badge-delivered { background: #d1e7dd; color: #0a3622; }
    .badge-cancelled { background: #f8d7da; color: #842029; }

    .queue-card {
        border: 1px solid #e9ecef;
        border-radius: 14px;
        padding: 1rem;
        background: #fff;
        height: 100%;
    }

    .timeline-wrapper {
        overflow-x: auto;
        padding-bottom: 8px;
    }

    .timeline-horizontal {
        display: flex;
        align-items: flex-start;
        gap: 0;
        min-width: 900px;
        margin: 0;
        padding: 0;
        list-style: none;
    }

    .step {
        position: relative;
        flex: 1 1 0;
        text-align: center;
        padding: 0 8px;
    }

    .step:not(:last-child)::after {
        content: "";
        position: absolute;
        top: 18px;
        left: 50%;
        width: 100%;
        height: 3px;
        background: #dee2e6;
        z-index: 1;
    }

    .step-dot {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        margin: 0 auto 10px auto;
        position: relative;
        z-index: 2;
        border: 4px solid #fff;
        box-shadow: 0 0 0 2px #dee2e6;
        background: #adb5bd;
    }

    .step-label {
        font-size: 0.85rem;
        font-weight: 600;
        line-height: 1.2;
    }

    .step-active .step-dot {
        background: #0d6efd;
    }

    .step-cancelled .step-dot {
        background: #dc3545;
    }

    .step-active .step-label {
        color: #212529;
    }

    .step-muted .step-label {
        color: #adb5bd;
    }
</style>

@if (selectedOrder == null)
{
    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="d-flex align-items-center gap-3">
                <h2 class="mb-0">Staff Order Tracking</h2>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(ViewBag.Message as string))
        {
            <div class="alert alert-success shadow-sm">@ViewBag.Message</div>
        }

        @if (!string.IsNullOrWhiteSpace(ViewBag.ErrorMessage as string))
        {
            <div class="alert alert-danger shadow-sm">@ViewBag.ErrorMessage</div>
        }

        @if (bulkResults.Any())
        {
            <div class="alert alert-info shadow-sm">
                <strong>Bulk Update Results</strong>
                <ul class="mb-0 mt-2">
                    @foreach (var result in bulkResults)
                    {
                        <li>@result</li>
                    }
                </ul>
            </div>
        }

        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card stat-card stat-card-green shadow-sm border-0 h-100">
                    <div class="card-body p-3">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <span class="text-muted small">Pending Orders</span>
                            <i class="bi bi-hourglass-split text-success fs-5"></i>
                        </div>
                        <p class="fs-3 fw-bold mb-0" style="color:#2d7a4f;">@pendingCount</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card stat-card stat-card-blue shadow-sm border-0 h-100">
                    <div class="card-body p-3">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <span class="text-muted small">Dispatched</span>
                            <i class="bi bi-truck text-primary fs-5"></i>
                        </div>
                        <p class="fs-3 fw-bold mb-0 text-primary">@dispatchedCount</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card stat-card stat-card-orange shadow-sm border-0 h-100">
                    <div class="card-body p-3">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <span class="text-muted small">Ready for Dispatch</span>
                            <i class="bi bi-box-seam text-warning fs-5"></i>
                        </div>
                        <p class="fs-3 fw-bold mb-0 text-warning">@readyCount</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card tracking-card mb-4">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-lg-6">
                        <form asp-action="StaffOrderTracking" method="get" class="row g-2">
                            <div class="col-md-8">
                                <label class="form-label">Search by Order ID</label>
                                <input name="orderId"
                                    value="@(searchedOrderId?.ToString() ?? "")"
                                    class="form-control"
                                    type="number"
                                    placeholder="Enter order ID" />
                            </div>
                            <div class="col-md-4 d-flex align-items-end">
                                <button class="btn btn-primary w-100" type="submit">Search</button>
                            </div>
                        </form>
                    </div>

                    <div class="col-lg-6">
                        <form asp-action="StaffOrderTracking" method="get" class="row g-2">
                            <div class="col-md-8">
                                <label class="form-label">Filter by Status</label>
                                <select name="status" class="form-select">
                                    <option value="">Select status</option>
                                    @foreach (var s in allStatuses)
                                    {
                                        if (selectedStatusText == s.ToString())
                                        {
                                            <option value="@s" selected>@s</option>
                                        }
                                        else
                                        {
                                            <option value="@s">@s</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <button class="btn btn-secondary w-100" type="submit">Filter</button>
                            </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <a asp-action="StaffOrderTracking" class="btn btn-dark w-100">Clear</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="card section-card mb-4">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="mb-0 fw-bold">Order List</h5>
            </div>

            <div class="card-body p-0">
                @if (!displayOrders.Any())
                {
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                        No orders found.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4"></th>
                                    <th>Order ID</th>
                                    <th>Order Date</th>
                                    <th>Customer ID</th>
                                    <th>Total Amount</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in displayOrders)
                                {
                                    var currentStatus = order.GetStatus();

                                    <tr>
                                        <td class="ps-4">
                                            <input class="form-check-input bulk-order-checkbox" type="checkbox" value="@order.GetOrderId()" />
                                        </td>
                                        <td class="fw-semibold">#@order.GetOrderId()</td>
                                        <td>@order.GetOrderDate().ToString("dd MMM yyyy, hh:mm tt")</td>
                                        <td>#@order.GetCustomerId()</td>
                                        <td class="fw-semibold">$@order.GetTotalAmount().ToString("0.00")</td>
                                        <td>
                                            <span class="badge @GetBadgeClass(currentStatus) rounded-pill">
                                                @currentStatus
                                            </span>
                                        </td>
                                        <td>
                                            <a asp-action="StaffOrderTracking"
                                            asp-route-timelineOrderId="@order.GetOrderId()"
                                            class="btn btn-sm btn-outline-dark">
                                                Update
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="card section-card mb-4">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="mb-0 fw-bold">Bulk Update Orders</h5>
            </div>

            <div class="card-body">
                <form asp-action="BulkUpdateOrderStatus" method="post" class="border rounded p-3">
                    <div class="text-muted small mb-3">
                        Tick orders in the order list above, then choose a status and submit.
                    </div>

                    <div class="row g-2">
                        <div class="col-md-4">
                            <label class="form-label">New Status</label>
                            <select name="newStatus" class="form-select" required>
                                @foreach (var s in allStatuses)
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Remark</label>
                            <input name="remark" class="form-control" placeholder="Bulk remark (required for some statuses)" />
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button class="btn btn-danger w-100" type="submit">Bulk Update</button>
                        </div>
                    </div>

                    <div id="bulkOrderIdsContainer"></div>
                </form>
            </div>
        </div>

        <div class="card section-card">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-send me-2 text-primary"></i>Dispatch Queue
                </h5>
            </div>

            <div class="card-body">
                @if (!readyOrders.Any())
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-check-circle fs-2 d-block mb-2 text-success"></i>
                        No orders waiting for dispatch.
                    </div>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var order in readyOrders.OrderBy(o => o.GetOrderDate()))
                        {
                            <div class="col-md-6 col-xl-4">
                                <div class="queue-card">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <h6 class="mb-1">Order #@order.GetOrderId()</h6>
                                            <div class="text-muted small">
                                                Customer #@order.GetCustomerId()
                                            </div>
                                        </div>
                                        <span class="badge @GetBadgeClass(order.GetStatus()) rounded-pill">
                                            @order.GetStatus()
                                        </span>
                                    </div>

                                    <div class="small text-muted mb-1">
                                        Order Date: @order.GetOrderDate().ToString("dd MMM yyyy, hh:mm tt")
                                    </div>
                                    <div class="small text-muted mb-3">
                                        Total: $@order.GetTotalAmount().ToString("0.00")
                                    </div>

                                    <div class="d-flex gap-2">
                                        <a asp-action="StaffOrderTracking"
                                        asp-route-timelineOrderId="@order.GetOrderId()"
                                        class="btn btn-sm btn-outline-dark">
                                            Update
                                        </a>
                                        <button type="button" class="btn btn-success btn-sm" disabled>
                                            Dispatch
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}
else
{
    var currentStatus = selectedOrder.GetStatus();

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Update Order #@selectedOrder.GetOrderId()</h2>
            <div class="text-muted">View timeline and update this order status.</div>
        </div>
        <a asp-action="StaffOrderTracking"
           class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Orders
        </a>
    </div>

    @if (!string.IsNullOrWhiteSpace(TempData["Message"]?.ToString()))
    {
        <div class="alert alert-success shadow-sm">
            @TempData["Message"]
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(TempData["ErrorMessage"]?.ToString()))
    {
        <div class="alert alert-danger shadow-sm">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="queue-card">
                <div class="text-muted small">Order ID</div>
                <div class="fw-semibold">#@selectedOrder.GetOrderId()</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="queue-card">
                <div class="text-muted small">Customer ID</div>
                <div class="fw-semibold">#@selectedOrder.GetCustomerId()</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="queue-card">
                <div class="text-muted small">Order Date</div>
                <div class="fw-semibold">@selectedOrder.GetOrderDate().ToString("dd MMM yyyy, hh:mm tt")</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="queue-card">
                <div class="text-muted small">Total Amount</div>
                <div class="fw-semibold">$@selectedOrder.GetTotalAmount().ToString("0.00")</div>
            </div>
        </div>
    </div>

    <div class="card tracking-card mb-4">
        <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold">Order Status</h5>
            <span class="badge @GetBadgeClass(currentStatus) rounded-pill fs-6">
                @currentStatus
            </span>
        </div>
        <div class="card-body">
            <div class="timeline-wrapper">
                <ul class="timeline-horizontal">
                    @foreach (var step in allStatuses)
                    {
                        <li class="@GetStepClass(step, currentStatus)">
                            <div class="step-dot"></div>
                            <div class="step-label">@step</div>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <div class="card section-card mb-4">
        <div class="card-header bg-white border-bottom py-3">
            <h5 class="mb-0 fw-bold">Single Update Status</h5>
        </div>
        <div class="card-body">
            <form asp-action="UpdateOrderStatus" method="post">
                <input type="hidden" name="orderId" value="@selectedOrder.GetOrderId()" />

                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">New Status</label>
                        <select name="newStatus" class="form-select" required>
                            @foreach (var s in allStatuses)
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Remark</label>
                        <input name="remark" class="form-control" placeholder="Remark" />
                    </div>

                    <div class="col-md-2 d-flex align-items-end">
                        <button class="btn btn-primary w-100" type="submit">Update</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card section-card">
        <div class="card-header bg-white border-bottom py-3">
            <h5 class="mb-0 fw-bold">Timeline History</h5>
        </div>
        <div class="card-body">
            @if (!selectedTimeline.Any())
            {
                <div class="alert alert-secondary mb-0">
                    No timeline records found for this order.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Status</th>
                                <th>Timestamp</th>
                                <th>Updated By</th>
                                <th>Remark</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in selectedTimeline.OrderByDescending(t => t.GetTimestamp()))
                            {
                                <tr>
                                    <td>
                                        <span class="badge @GetBadgeClass(item.GetStatus()) rounded-pill">
                                            @item.GetStatus()
                                        </span>
                                    </td>
                                    <td>@item.GetTimestamp().ToString("dd MMM yyyy, hh:mm tt")</td>
                                    <td>@item.GetUpdatedBy()</td>
                                    <td>@(string.IsNullOrWhiteSpace(item.GetRemark()) ? "—" : item.GetRemark())</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@section Scripts {
    <script>
        (() => {
            const container = document.getElementById("bulkOrderIdsContainer");
            const checkboxes = document.querySelectorAll(".bulk-order-checkbox");
            const bulkForm = document.querySelector('form[action*="BulkUpdateOrderStatus"]');

            if (!container || !bulkForm) return;

            function syncHiddenInputs() {
                container.innerHTML = "";

                checkboxes.forEach(cb => {
                    if (cb.checked) {
                        const input = document.createElement("input");
                        input.type = "hidden";
                        input.name = "orderIds";
                        input.value = cb.value;
                        container.appendChild(input);
                    }
                });
            }

            checkboxes.forEach(cb => {
                cb.addEventListener("change", syncHiddenInputs);
            });

            bulkForm.addEventListener("submit", syncHiddenInputs);
        })();
    </script>
}