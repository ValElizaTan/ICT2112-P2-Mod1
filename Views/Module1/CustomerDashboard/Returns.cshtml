@using System.Reflection
@{
    ViewData["Title"] = "My Returns";
    var returns = ViewData["Returns"] as List<ProRental.Domain.Entities.Returnrequest>;
    var customerId = ViewData["CustomerId"] as int? ?? 0;

    // Helper function to get private field value
    T? GetFieldValue<T>(object obj, string fieldName)
    {
        var field = obj.GetType().GetField(fieldName, BindingFlags.NonPublic | BindingFlags.Instance);
        if (field == null) return default;
        return (T?)field.GetValue(obj);
    }
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>My Returns</h2>
        <a asp-action="Index" asp-route-customerId="@customerId" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom py-3">
            <h5 class="mb-0 fw-bold">Return History</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Return ID</th>
                            <th>Order ID</th>
                            <th>Request Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (returns != null && returns.Any())
                        {
                            foreach (var returnReq in returns)
                            {
                                var returnId = GetFieldValue<int>(returnReq, "_returnrequestid");
                                var orderId = GetFieldValue<int>(returnReq, "_orderid");
                                var requestDate = GetFieldValue<DateTime>(returnReq, "_requestdate");
                                <tr>
                                    <td class="ps-3">#@returnId</td>
                                    <td>#@orderId</td>
                                    <td>@requestDate.ToString("dd MMM yyyy")</td>
                                    <td><span class="badge bg-info">Processing</span></td>
                                    <td>
                                        <a asp-action="ReturnDetails" asp-route-returnRequestId="@returnId"
                                               class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i> View
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                    No return requests found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="alert alert-info mt-4">
        <i class="bi bi-info-circle me-2"></i>
        To initiate a return, please go to your order details page for orders that have been delivered.
    </div>
</div>