@using System.Reflection
@using ProRental.Domain.Enums
@{
    ViewData["Title"] = "My Returns";
    var returns = ViewData["Returns"] as List<ProRental.Domain.Entities.Returnrequest>;
    var orderLookup = ViewData["OrderLookup"] as Dictionary<int, ProRental.Domain.Entities.Order>
                      ?? new Dictionary<int, ProRental.Domain.Entities.Order>();
    var customerId = ViewData["CustomerId"] as int? ?? 0;
    var control = ViewData["Control"] as ProRental.Domain.Module1.P24.Controls.CustomerDashboardControl;

    // Helper function to get private field value
    T? GetFieldValue<T>(object obj, string fieldName)
    {
        var field = obj.GetType().GetField(fieldName, BindingFlags.NonPublic | BindingFlags.Instance);
        if (field == null) return default;
        return (T?)field.GetValue(obj);
    }
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>My Returns</h2>
        <a asp-action="Index" asp-route-customerId="@customerId" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom py-3">
            <h5 class="mb-0 fw-bold">Return History</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Order ID</th>
                            <th>Order Date</th>
                            <th>Total Amount</th>
                            <th>Return Date</th>
                            <th>Return Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (returns != null && returns.Any())
                        {
                            foreach (var returnReq in returns)
                            {
                                var orderId = GetFieldValue<int>(returnReq, "_orderid");
                                var requestDate = GetFieldValue<DateTime>(returnReq, "_requestdate");
                                var returnStatusObj = GetFieldValue<object>(returnReq, "_status");
                                var returnStatus = returnStatusObj?.ToString() ?? "Processing";

                                // Get order details from lookup
                                orderLookup.TryGetValue(orderId, out var order);
                                var orderDate = order != null && control != null ? control.GetOrderDate(order) : DateTime.MinValue;
                                var totalAmount = order != null && control != null ? control.GetTotalAmount(order) : 0m;

                                var statusBadge = returnStatus.ToLower() switch
                                {
                                    "completed" => "bg-success",
                                    "approved" => "bg-success",
                                    "rejected" => "bg-danger",
                                    _ => "bg-info"
                                };

                                <tr>
                                    <td class="ps-3 fw-semibold small">#@orderId</td>
                                    <td class="small">@(orderDate != DateTime.MinValue ? orderDate.ToString("dd MMM yyyy") : "—")</td>
                                    <td class="small fw-semibold">$@totalAmount.ToString("0.00")</td>
                                    <td class="small">@requestDate.ToString("dd MMM yyyy")</td>
                                    <td><span class="badge @statusBadge rounded-pill">@returnStatus</span></td>
                                    <td>
                                        <a asp-action="OrderDetails" asp-route-orderId="@orderId"
                                               asp-route-customerId="@customerId"
                                               class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye me-1"></i>View Order
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                    No return requests found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="alert alert-info mt-4">
        <i class="bi bi-info-circle me-2"></i>
        To initiate a return, please go to your order details page for orders that have been delivered.
    </div>
</div>