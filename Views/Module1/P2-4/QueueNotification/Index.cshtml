@using ProRental.Domain.Enums
@{
    ViewData["Title"] = "Queue Notification";
    int userId = ViewData["UserId"] is int uid ? uid : 1;
    var types = ViewData["NotificationTypes"] as List<NotificationType> ?? new List<NotificationType>();
    string successMessage = ViewData["SuccessMessage"] as string ?? string.Empty;
}

<h1 class="mb-3">Queue Notification</h1>

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

<form method="post" asp-action="Index" asp-controller="NotificationCreation" class="card p-4 mb-4">
    <div class="mb-3 row">
        <label class="col-sm-2 col-form-label">User ID</label>
        <div class="col-sm-4">
            <input type="number" name="userId" class="form-control" value="@userId" min="1" required />
        </div>
    </div>

    <div class="mb-3 row">
        <label class="col-sm-2 col-form-label">Type</label>
        <div class="col-sm-4">
            <select name="type" class="form-select" required>
                @foreach (var item in types)
                {
                    <option value="@item">@item</option>
                }
            </select>
        </div>
    </div>

    <div class="mb-3 row">
        <label class="col-sm-2 col-form-label">Message</label>
        <div class="col-sm-8">
            <textarea name="message" class="form-control" rows="4" placeholder="Enter notification text" required></textarea>
            @if (!string.IsNullOrEmpty(ViewData.ModelState["Message"]?.Errors.FirstOrDefault()?.ErrorMessage))
            {
                <div class="text-danger">@ViewData.ModelState["Message"]?.Errors.First().ErrorMessage</div>
            }
        </div>
    </div>

    <div class="row">
        <div class="col-sm-10">
            <button type="submit" class="btn btn-primary">Queue Notification</button>
            <a asp-controller="StaffDashboard" asp-action="Index" class="btn btn-secondary ms-2">Back to Dashboard</a>
        </div>
    </div>

    @Html.AntiForgeryToken()
</form>
