@{
    ViewData["Title"] = "New Walk-in Customer";
}

<div class="container py-4">

    <div class="d-flex align-items-center gap-2 mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <h1 class="h4 fw-semibold mb-0">New Walk-in Customer</h1>
            <p class="text-muted small mb-0">Enter the customer's details to proceed</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">

                    <form asp-action="EnterCustomerDetails" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label fw-semibold" for="customerName">
                                <i class="bi bi-person me-1 text-primary"></i>Full Name
                            </label>
                            <input type="text"
                                   id="customerName"
                                   name="customerName"
                                   class="form-control"
                                   placeholder="e.g. John Tan"
                                   required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold" for="customerEmail">
                                <i class="bi bi-envelope me-1 text-primary"></i>Email Address
                            </label>
                            <input type="email"
                                   id="customerEmail"
                                   name="customerEmail"
                                   class="form-control"
                                   placeholder="e.g. john@example.com"
                                   required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold" for="customerAddress">
                                <i class="bi bi-geo-alt me-1 text-primary"></i>Address
                            </label>
                            <input type="text"
                                   id="customerAddress"
                                   name="customerAddress"
                                   class="form-control"
                                   placeholder="e.g. 123 Orchard Road, Singapore" />
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-arrow-right me-2"></i>Continue to Select Products
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>

</div>
