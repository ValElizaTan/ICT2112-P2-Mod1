@model List<ProRental.Domain.Entities.Product>
@{
    ViewData["Title"] = "Select Products";
}

<style>
    .wio-step-dot { width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.8rem;font-weight:600;flex-shrink:0; }
    .wio-step-dot.done  { background:#2d7a4f;color:#fff; }
    .wio-step-dot.active{ background:#2d7a4f;color:#fff;box-shadow:0 0 0 4px rgba(45,122,79,.18); }
    .wio-step-dot.idle  { background:#dee2e6;color:#6c757d; }
    .wio-step-line      { flex-grow:1;height:2px;margin:0 4px;margin-bottom:18px; }
    .wio-step-line.done { background:#2d7a4f; }
    .wio-step-line.idle { background:#dee2e6; }
    .wio-step-label     { font-size:.7rem;margin-top:4px;white-space:nowrap; }

    .product-card { border:2px solid #dee2e6; border-radius:.5rem; transition:border-color .15s,background .15s; cursor:pointer; }
    .product-card:hover { border-color:#adb5bd; }
    .product-card.selected { border-color:#2d7a4f; background:rgba(45,122,79,.04); }
</style>

<div class="d-flex align-items-center gap-2 mt-4 mb-3">
    <a asp-controller="StaffDashboard" asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Dashboard
    </a>
    <h4 class="mb-0 fw-bold"><i class="bi bi-person-walking me-2" style="color:#2d7a4f;"></i>Walk-In Order</h4>
</div>

<div class="d-flex align-items-start mb-4">
    <div class="text-center"><div class="wio-step-dot done"><i class="bi bi-check-lg"></i></div><div class="wio-step-label fw-semibold" style="color:#2d7a4f;">Details</div></div>
    <div class="wio-step-line done"></div>
    <div class="text-center"><div class="wio-step-dot active">2</div><div class="wio-step-label fw-semibold" style="color:#2d7a4f;">Products</div></div>
    <div class="wio-step-line idle"></div>
    <div class="text-center"><div class="wio-step-dot idle">3</div><div class="wio-step-label text-muted">Review</div></div>
    <div class="wio-step-line idle"></div>
    <div class="text-center"><div class="wio-step-dot idle"><i class="bi bi-check-lg"></i></div><div class="wio-step-label text-muted">Confirmed</div></div>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-warning d-flex align-items-center gap-2 py-2" role="alert">
        <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
        <span class="small">@TempData["ErrorMessage"]</span>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
        <h6 class="fw-bold mb-0"><i class="bi bi-grid me-2" style="color:#2d7a4f;"></i>Select Products</h6>
        <div class="input-group" style="max-width:280px;">
            <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
            <input type="text" id="productSearch" class="form-control form-control-sm" placeholder="Search products..." autocomplete="off" />
        </div>
    </div>
    <div class="card-body">
        <form asp-action="ReviewOrder" method="get">
            @if (Model == null || !Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-box-seam fs-1 d-block mb-3 text-secondary"></i>
                    <p class="mb-1 fw-semibold">No products available</p>
                    <p class="small">The inventory is currently empty.</p>
                </div>
            }
            else
            {
                <div class="row g-3 mb-3" id="productGrid">
                    @foreach (var product in Model)
                    {
                        var pid = product.GetProductId();
                        var name = product.GetProductName();
                        var price = product.GetPrice();
                        var desc = product.GetDescription();
                        var img = product.GetImageUrl();
                        var category = product.GetCategoryName();

                        <div class="col-12 col-sm-6 col-lg-4 product-item" data-name="@name.ToLower()" data-category="@category.ToLower()">
                            <label class="product-card d-block p-3 h-100" for="prod_@pid" id="card_@pid">
                                <input type="checkbox" name="productIds" value="@pid" id="prod_@pid" class="d-none product-checkbox" />
                                <div class="d-flex gap-3">
                                    @if (!string.IsNullOrEmpty(img))
                                    {
                                        <img src="@img" alt="@name" class="rounded flex-shrink-0" style="width:64px;height:64px;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <div class="rounded bg-light d-flex align-items-center justify-content-center flex-shrink-0" style="width:64px;height:64px;">
                                            <i class="bi bi-box-seam text-muted fs-4"></i>
                                        </div>
                                    }
                                    <div class="flex-grow-1 overflow-hidden">
                                        <div class="fw-semibold text-truncate">@name</div>
                                        @if (!string.IsNullOrEmpty(category))
                                        {
                                            <span class="badge bg-light text-dark border mb-1" style="font-size:.68rem;">@category</span>
                                        }
                                        <div class="fw-bold" style="color:#2d7a4f;">$@price.ToString("F2")</div>
                                    </div>
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-check-circle-fill text-success fs-5 check-icon" style="display:none;"></i>
                                    </div>
                                </div>
                            </label>
                        </div>
                    }
                </div>

                <div id="noResults" class="text-center text-muted py-4 d-none">
                    <i class="bi bi-search fs-3 d-block mb-2"></i>No products match your search.
                </div>

                <div class="border-top pt-3">
                    <span class="small text-muted" id="selectionCount">0 product(s) selected</span>
                </div>
            }

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary">Next: Review Order <i class="bi bi-arrow-right ms-1"></i></button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Toggle card selection visual
        document.querySelectorAll('.product-checkbox').forEach(cb => {
            cb.addEventListener('change', function () {
                const card = document.getElementById('card_' + this.value);
                const icon = card.querySelector('.check-icon');
                card.classList.toggle('selected', this.checked);
                icon.style.display = this.checked ? 'inline' : 'none';
                updateCount();
            });
        });

        function updateCount() {
            const count = document.querySelectorAll('.product-checkbox:checked').length;
            document.getElementById('selectionCount').textContent = count + ' product(s) selected';
        }

        // Search / filter
        document.getElementById('productSearch')?.addEventListener('input', function () {
            const query = this.value.toLowerCase().trim();
            const items = document.querySelectorAll('.product-item');
            let visible = 0;
            items.forEach(item => {
                const match = !query || item.dataset.name.includes(query) || item.dataset.category.includes(query);
                item.classList.toggle('d-none', !match);
                if (match) visible++;
            });
            document.getElementById('noResults')?.classList.toggle('d-none', visible > 0);
        });
    </script>
}
