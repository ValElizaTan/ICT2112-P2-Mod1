@{
    ViewData["Title"] = "Shipping Dashboard";
    var activeShipments = ViewData["ActiveShipments"] as List<ProRental.Domain.Module1.P24.Entities.Shipment> ?? new();
    var carriers = ViewData["Carriers"] as List<ProRental.Domain.Module1.P24.Entities.CarrierAgent> ?? new();
}

<div class="row mb-4">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="mb-0">
                    <i class="bi bi-truck me-2" style="color: #2d7a4f;"></i>Shipping Dashboard
                </h1>
                <p class="text-muted mb-0">Manage shipments and carrier assignments</p>
            </div>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#filterModal">
                <i class="bi bi-funnel me-1"></i>Filter Shipments
            </button>
        </div>
    </div>
</div>

    <!-- Carrier Agents Overview -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light border-0 py-3">
                    <h5 class="mb-0">
                        <i class="bi bi-building me-2" style="color: #2d7a4f;"></i>Active Carrier Agents
                    </h5>
                </div>
                <div class="card-body">
                    @if (carriers.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Carrier Name</th>
                                        <th>Status</th>
                                        <th>Capacity (kg)</th>
                                        <th>Services</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var carrier in carriers)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@carrier.GetName()</td>
                                            <td>
                                                @if (carrier.IsActive())
                                                {
                                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Active</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary"><i class="bi bi-x-circle me-1"></i>Inactive</span>
                                                }
                                            </td>
                                            <td>@carrier.GetCapacity().ToString("N0")</td>
                                            <td>
                                                @{
                                                    var services = carrier.GetServicesAvailable();
                                                    if (services.Count > 0)
                                                    {
                                                        <span class="badge bg-info">@string.Join(", ", services.Take(2).Select(s => s.ToString()))</span>
                                                        if (services.Count > 2)
                                                        {
                                                            <span class="badge bg-info">+@(services.Count - 2)</span>
                                                        }
                                                    }
                                                }
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-outline-primary" 
                                                        data-carrier-id="@carrier.GetCarrierId()"
                                                        onclick="viewCarrierShipments(@carrier.GetCarrierId())">
                                                    View Shipments
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No carriers available</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Active Shipments -->
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light border-0 py-3">
                    <h5 class="mb-0">
                        <i class="bi bi-box-seam me-2" style="color: #2d7a4f;"></i>Active Shipments
                    </h5>
                </div>
                <div class="card-body">
                    @if (activeShipments.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Tracking ID</th>
                                        <th>Order ID</th>
                                        <th>Status</th>
                                        <th>Priority</th>
                                        <th>Weight (kg)</th>
                                        <th>ETA</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var shipment in activeShipments)
                                    {
                                        <tr>
                                            <td class="fw-semibold">#@shipment.GetTrackingId()</td>
                                            <td>#@shipment.GetOrderId()</td>
                                            <td>
                                                @{
                                                    var statusBadgeClass = shipment.GetStatus() switch
                                                    {
                                                        ProRental.Domain.Enums.ShipmentStatus.PENDING => "bg-warning",
                                                        ProRental.Domain.Enums.ShipmentStatus.IN_TRANSIT => "bg-info",
                                                        ProRental.Domain.Enums.ShipmentStatus.DELIVERED => "bg-success",
                                                        ProRental.Domain.Enums.ShipmentStatus.CANCELLED => "bg-danger",
                                                        _ => "bg-secondary"
                                                    };
                                                }
                                                <span class="badge @statusBadgeClass">@shipment.GetStatus()</span>
                                            </td>
                                            <td>
                                                @{
                                                    var priorityBadgeClass = shipment.GetPriority() switch
                                                    {
                                                        ProRental.Domain.Module1.P24.Entities.ShipmentPriority.Urgent => "bg-danger",
                                                        ProRental.Domain.Module1.P24.Entities.ShipmentPriority.High => "bg-warning",
                                                        ProRental.Domain.Module1.P24.Entities.ShipmentPriority.Medium => "bg-info",
                                                        _ => "bg-secondary"
                                                    };
                                                }
                                                <span class="badge @priorityBadgeClass">@shipment.GetPriority()</span>
                                            </td>
                                            <td>@shipment.GetWeight().ToString("F2")</td>
                                            <td>@shipment.GetEstimatedArrival().ToString("yyyy-MM-dd HH:mm")</td>
                                            <td>
                                                <div class="btn-group btn-group-sm" role="group">
                                                    <button type="button" class="btn btn-outline-primary" 
                                                            onclick="viewShipmentDetails(@shipment.GetTrackingId())">
                                                        Details
                                                    </button>
                                                    <button type="button" class="btn btn-outline-secondary" 
                                                            data-bs-toggle="modal" data-bs-target="#reassignModal"
                                                            data-tracking-id="@shipment.GetTrackingId()">
                                                        Reassign
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No active shipments</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Filter Modal -->
<div class="modal fade" id="filterModal" tabindex="-1" aria-labelledby="filterModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="filterModalLabel">Filter Shipments</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="filterForm">
                    <div class="mb-3">
                        <label for="fromDate" class="form-label">From Date</label>
                        <input type="date" class="form-control" id="fromDate" name="fromDate">
                    </div>
                    <div class="mb-3">
                        <label for="toDate" class="form-label">To Date</label>
                        <input type="date" class="form-control" id="toDate" name="toDate">
                    </div>
                    <div class="mb-3">
                        <label for="carrierId" class="form-label">Carrier</label>
                        <select class="form-control" id="carrierId" name="carrierId">
                            <option value="">-- All Carriers --</option>
                            @foreach (var carrier in carriers)
                            {
                                <option value="@carrier.GetCarrierId()">@carrier.GetName()</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="status" class="form-label">Status</label>
                        <select class="form-control" id="status" name="status">
                            <option value="">-- All Status --</option>
                            <option value="Pending">Pending</option>
                            <option value="InTransit">In Transit</option>
                            <option value="Delivered">Delivered</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="applyFilters()">Apply Filters</button>
            </div>
        </div>
    </div>
</div>

<!-- Reassign Modal -->
<div class="modal fade" id="reassignModal" tabindex="-1" aria-labelledby="reassignModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="reassignModalLabel">Reassign Carrier</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="reassignTrackingId">
                <div class="mb-3">
                    <label for="newCarrierId" class="form-label">Select New Carrier</label>
                    <select class="form-control" id="newCarrierId" name="newCarrierId">
                        <option value="">-- Select a carrier --</option>
                        @foreach (var carrier in carriers.Where(c => c.IsActive()))
                        {
                            <option value="@carrier.GetCarrierId()">@carrier.GetName() (@carrier.GetCapacity()kg)</option>
                        }
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="reassignCarrier()">Reassign</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function viewCarrierShipments(carrierId) {
            // TODO: Navigate to carrier shipments view
            alert(`View shipments for carrier ${carrierId}`);
        }

        function viewShipmentDetails(trackingId) {
            // TODO: Navigate to shipment details view
            alert(`View details for shipment ${trackingId}`);
        }

        function applyFilters() {
            const fromDate = document.getElementById('fromDate').value;
            const toDate = document.getElementById('toDate').value;
            const carrierId = document.getElementById('carrierId').value;
            const status = document.getElementById('status').value;

            const data = {
                fromDate: fromDate ? new Date(fromDate) : null,
                toDate: toDate ? new Date(toDate) : null,
                carrierId: carrierId ? parseInt(carrierId) : null,
                status: status || null,
                route: null
            };

            // TODO: Call API to filter shipments
            console.log('Filter data:', data);
        }

        function reassignCarrier() {
            const trackingId = document.getElementById('reassignTrackingId').value;
            const newCarrierId = document.getElementById('newCarrierId').value;

            if (!newCarrierId) {
                alert('Please select a carrier');
                return;
            }

            // TODO: Call API to reassign carrier
            console.log(`Reassigning shipment ${trackingId} to carrier ${newCarrierId}`);
        }

        // Handle reassign modal opening
        document.getElementById('reassignModal')?.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const trackingId = button.getAttribute('data-tracking-id');
            document.getElementById('reassignTrackingId').value = trackingId;
        });
    </script>
}
