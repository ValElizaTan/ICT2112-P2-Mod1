@model List<ProRental.Domain.Entities.Shipment>

@{
    ViewData["Title"] = "Shipping Dashboard";
    var filtered = ViewBag.FilteredId != null;
    var single   = filtered && Model?.Count == 1 ? Model[0].GetShipmentInfo() : null;
}

<style>
    .stat-card { border-left: 4px solid transparent; transition: box-shadow .2s; }
    .stat-card:hover { box-shadow: 0 .5rem 1.25rem rgba(0,0,0,.12) !important; }
    .stat-card-blue   { border-left-color: #0d6efd; }
    .stat-card-green  { border-left-color: #2d7a4f; }
    .stat-card-orange { border-left-color: #fd7e14; }
    .badge-dispatched { background: #cfe2ff; color: #084298; }
    .badge-pending    { background: #fff3cd; color: #856404; }
    .badge-ready      { background: #d1e7dd; color: #0a3622; }
    .info-label { font-size: .72rem; text-transform: uppercase; letter-spacing: .04em; color: #6c757d; font-weight: 600; }
    .info-value { font-size: .92rem; }
    .tbl thead th { font-size: .78rem; }
    .badge-xs { font-size: .7rem; }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center gap-3">
        <a asp-controller="StaffDashboard" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
        @if (filtered)
        {
            <a asp-action="DisplayShipmentList" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-list me-1"></i>All Shipments
            </a>
        }
        <h5 class="mb-0 fw-bold">
            <i class="bi bi-truck me-2 text-primary"></i>
            @(filtered ? $"Shipment #{ViewBag.FilteredId}" : "All Shipments")
        </h5>
    </div>
    <form asp-controller="Shipping" asp-action="UpdateManualStatus" method="post">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-primary btn-sm">
            <i class="bi bi-send me-1"></i>Process Dispatch
        </button>
    </form>
</div>

@if (single != null)
{
    <!-- ── Single shipment detail view ── -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card stat-card stat-card-blue shadow-sm border-0 h-100">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <span class="text-muted small">Tracking ID</span>
                        <i class="bi bi-upc-scan text-primary fs-5"></i>
                    </div>
                    <p class="fs-4 fw-bold mb-0 text-primary">#@single.TrackingId</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card stat-card-green shadow-sm border-0 h-100">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <span class="text-muted small">Dispatch Status</span>
                        <i class="bi bi-check-circle text-success fs-5"></i>
                    </div>
                    <p class="fs-5 fw-bold mb-0">
                        @if (single.DispatchStatus)
                        {
                            <span class="badge badge-dispatched rounded-pill">Dispatched</span>
                        }
                        else
                        {
                            <span class="badge badge-pending rounded-pill">Pending</span>
                        }
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card stat-card-orange shadow-sm border-0 h-100">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <span class="text-muted small">Weight</span>
                        <i class="bi bi-box-seam text-warning fs-5"></i>
                    </div>
                    <p class="fs-4 fw-bold mb-0 text-warning">@single.Weight <small class="fs-6 fw-normal text-muted">kg</small></p>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom py-3">
            <h6 class="fw-bold mb-0"><i class="bi bi-list-ul me-2 text-primary"></i>Shipment Details</h6>
        </div>
        <div class="card-body">
            <div class="row g-4">
                <div class="col-md-6">
                    <p class="info-label mb-1">Tracking ID</p>
                    <p class="info-value mb-3">#@single.TrackingId</p>
                    <p class="info-label mb-1">Destination Address</p>
                    <p class="info-value mb-3">@(string.IsNullOrEmpty(single.DestinationAddress) ? "—" : single.DestinationAddress)</p>
                    <p class="info-label mb-1">Batch ID</p>
                    <p class="info-value mb-0">#@single.BatchId</p>
                </div>
                <div class="col-md-6">
                    <p class="info-label mb-1">Weight</p>
                    <p class="info-value mb-3">@single.Weight kg</p>
                    <p class="info-label mb-1">Dispatch Status</p>
                    <p class="info-value mb-0">
                        @if (single.DispatchStatus)
                        {
                            <span class="badge badge-dispatched rounded-pill">Dispatched</span>
                        }
                        else
                        {
                            <span class="badge badge-pending rounded-pill">Pending Dispatch</span>
                        }
                    </p>
                </div>
            </div>
        </div>
    </div>
}
else if (Model == null || !Model.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-inbox fs-2 d-block mb-2"></i>No shipments found.
    </div>
}
else
{
    <!-- ── Full list view ── -->
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom py-3">
            <h6 class="fw-bold mb-0"><i class="bi bi-list-ul me-2 text-primary"></i>Shipment List</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 tbl">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Tracking ID</th>
                            <th>Batch ID</th>
                            <th>Destination</th>
                            <th>Weight</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
    @foreach (var shipment in Model)
    {
        var info = shipment.GetShipmentInfo();
        <tr style="cursor:pointer;" onclick="window.location='@Url.Action("DisplayShipmentList", "Shipping", new { trackingId = info.TrackingId })'">
            <td class="ps-3 fw-semibold small">#@info.TrackingId</td>
            <td class="small">#@info.BatchId</td>
            <td class="small text-muted">@(string.IsNullOrEmpty(info.DestinationAddress) ? "—" : info.DestinationAddress)</td>
            <td class="small">@info.Weight kg</td>
            <td>
                @if (info.DispatchStatus)
                {
                    <span class="badge badge-dispatched rounded-pill">Dispatched</span>
                }
                else
                {
                    <span class="badge badge-pending rounded-pill">Pending</span>
                }
            </td>
        </tr>
    }
</tbody>
                </table>
            </div>
        </div>
    </div>
}