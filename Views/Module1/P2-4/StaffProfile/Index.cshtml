@{
    ViewData["Title"] = "Staff Profile";
}

<style>
    .profile-avatar {
        width: 64px; height: 64px;
        background: rgba(13,110,253,.10);
        color: #0d6efd;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.6rem; font-weight: 700;
        flex-shrink: 0;
    }
    .info-label  { font-size: .72rem; text-transform: uppercase; letter-spacing: .04em; color: #6c757d; font-weight: 600; }
    .info-value  { font-size: .92rem; }
    .section-divider { border-left: 3px solid #0d6efd; }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center gap-3">
        <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
        <h5 class="mb-0 fw-bold">Staff Profile</h5>
    </div>
</div>
<div class="row g-4">
    <div class="col-lg-4">
        @await Html.PartialAsync("StaffProfileSections/_StaffIdentityCard")
    </div>
    <div class="col-lg-8">
        @await Html.PartialAsync("StaffProfileSections/_StaffEditForm")
        @await Html.PartialAsync("StaffProfileSections/_StaffActivitySummary")
    </div>
</div>
<div class="row g-4 mt-1">
    <div class="col-12">
        @await Html.PartialAsync("StaffProfileSections/_StaffManagement")
    </div>
</div>
