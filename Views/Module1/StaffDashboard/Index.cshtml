@using ProRental.Domain.Entities
@using ProRental.Domain.Enums
@{
    
    ViewData["Title"] = "Staff Dashboard";
    string staffName = ViewBag.StaffName ?? "Staff";
    string staffRole = ViewBag.StaffRole ?? "Staff";
    int unreadNotifs = ViewBag.UnreadNotifications ?? 0;
     var allOrders        = ViewBag.Orders as List<Order> ?? new List<Order>();
    var pendingOrders   = allOrders.Where(o => o.GetStatus() == OrderStatus.PENDING).ToList();
    var dispatchedOrders = allOrders.Where(o => o.GetStatus() == OrderStatus.DISPATCHED).ToList();
    var cancelledOrders = allOrders.Where(o => o.GetStatus() == OrderStatus.CANCELLED).ToList();
    var readyForDispatchOrders = allOrders.Where(o => o.GetStatus() == OrderStatus.READY_FOR_DISPATCH).ToList();
    var allStatuses = new List<OrderStatus>
    {
        OrderStatus.PENDING,
        OrderStatus.CONFIRMED,
        OrderStatus.PROCESSING,
        OrderStatus.READY_FOR_DISPATCH,
        OrderStatus.DISPATCHED,
        OrderStatus.DELIVERED,
        OrderStatus.CANCELLED
    };
}

<style>
    .stat-card { border-left: 4px solid transparent; transition: box-shadow .2s; }
    .stat-card:hover { box-shadow: 0 .5rem 1.25rem rgba(0,0,0,.12) !important; }
    .stat-card-green  { border-left-color: #2d7a4f; }
    .stat-card-blue   { border-left-color: #0d6efd; }
    .stat-card-orange { border-left-color: #fd7e14; }
    .stat-card-red    { border-left-color: #dc3545; }

   .badge-pending { background: #fff3cd; color: #856404; }
    .badge-confirmed { background: #cff4fc; color: #055160; }
    .badge-processing { background: #ffe5b4; color: #7a4b00; }
    .badge-ready { background: #d1e7dd; color: #0a3622; }
    .badge-dispatched { background: #cfe2ff; color: #084298; }
    .badge-delivered { background: #d1e7dd; color: #0a3622; }
    .badge-cancelled { background: #f8d7da; color: #842029; }

    .sidebar-nav .nav-link { color: #495057; border-radius: .375rem; padding: .5rem .85rem; font-size: .875rem; }
    .sidebar-nav .nav-link.active,
    .sidebar-nav .nav-link:hover { background: rgba(45,122,79,.12); color: #2d7a4f; }
    .sidebar-nav .nav-link.active { font-weight: 600; }

    .table-hover tbody tr:hover { background: rgba(45,122,79,.06); }
    .tbl thead th { font-size: .78rem; }
    .badge-xs { font-size: .7rem; }
    .notif-badge { font-size: .6rem; top: -4px; right: -6px; }

    /* _ShippingPartial */
    .agent-cap-bar  { height: 6px   ; border-radius: 3px; background: #e9ecef; }
    .agent-cap-fill { height: 100%; border-radius: 3px; background: #2d7a4f; transition: width .4s; }
    
    .custom-sticky-sidebar {
    position: sticky;
    top: 76px;
    overflow-y: auto;
    }   

    /* Optional: Make the scrollbar look cleaner */
    .custom-sticky-sidebar::-webkit-scrollbar {
        width: 6px;
    }
    .custom-sticky-sidebar::-webkit-scrollbar-thumb {
        background-color: #dee2e6;
        border-radius: 4px;
    }
    .dashboard-content [id] {
        scroll-margin-top: 100px; 
        /* adjustment fix */
    }
</style>

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4 p-3 rounded-4 border bg-white shadow-sm">
    <div class="d-flex align-items-center gap-3">
        <div class="d-flex align-items-center justify-content-center rounded-3 bg-light border" style="width: 48px; height: 48px;">
            <i class="bi bi-speedometer2 fs-4 text-primary"></i>
        </div>
        <div>
            <h2 class="mb-0 fw-bold">Staff Dashboard</h2>
            <small class="text-muted">Manage notifications, profile, and staff actions</small>
        </div>
    </div>

    <div class="d-flex flex-wrap align-items-center justify-content-lg-end gap-2">
        <a asp-action="OnNavigateToStaffProfile" class="btn btn-light btn-sm border rounded-pill px-3">
            <i class="bi bi-person-circle me-1"></i>Staff Profile
        </a>

        <div class="position-relative">
            <button class="btn btn-light btn-sm border rounded-pill px-3 position-relative" data-bs-toggle="offcanvas" data-bs-target="#notifDrawer">
                <i class="bi bi-bell me-1"></i>Notifications
                @if (unreadNotifs > 0)
                {
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger notif-badge">
                        @unreadNotifs
                    </span>
                }
            </button>
        </div>

        <a asp-controller="NotificationSettings" asp-action="Index" asp-route-role="staff" class="btn btn-light btn-sm border rounded-pill px-3">
            <i class="bi bi-gear me-1"></i>Settings
        </a>

        <a href="/QueueNotification" class="btn btn-success btn-sm rounded-pill px-3">
            <i class="bi bi-bell-plus me-1"></i>Queue Notification
        </a>

        <a asp-action="OnLogout" class="btn btn-outline-danger btn-sm rounded-pill px-3">
            <i class="bi bi-box-arrow-right me-1"></i>Logout
        </a>
    </div>
</div>

<div class="offcanvas offcanvas-end" tabindex="-1" id="notifDrawer">
    <div class="offcanvas-header border-bottom">
        <h6 class="offcanvas-title fw-bold"><i class="bi bi-bell me-2"></i>Notifications</h6>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body p-0">
        @if (ViewBag.Notifications != null && ((IEnumerable<dynamic>)ViewBag.Notifications).Any())
        {
            foreach (var n in ViewBag.Notifications)
            {
                <div class="d-flex gap-3 p-3 border-bottom @(n.IsRead ? "" : "bg-light")">
                    <i class="bi bi-info-circle-fill text-primary mt-1 flex-shrink-0"></i>
                    <div>
                        <p class="mb-0 small fw-semibold">@n.Title</p>
                        <p class="mb-0 small text-muted">@n.Body</p>
                        <span class="small text-muted" style="font-size:.7rem;">@n.CreatedAt.ToString("d MMM HH:mm")</span>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center text-muted py-5 small">
                <i class="bi bi-check-circle fs-3 d-block mb-2 text-success"></i>All caught up!
            </div>
        }
    </div>
</div>

<div class="row mb-4 g-3">
    <div class="col-md-4">
        <div class="card text-center h-100">
            <div class="card-body">
                <h5 class="card-title">Walk-In Order</h5>
                <p class="card-text text-muted small">Create an order for a walk-in customer.</p>
                <div class="d-flex gap-2 justify-content-center">
                    <a asp-action="OnNavigateToWalkIn" asp-route-type="new" class="btn btn-primary btn-sm">New Customer</a>
                    <a asp-action="OnNavigateToWalkIn" asp-route-type="existing" class="btn btn-outline-primary btn-sm">Existing</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center h-100">
            <div class="card-body">
                <h5 class="card-title">Shipping</h5>
                <p class="card-text text-muted small">Manage shipments and dispatch status.</p>
                <a asp-action="OnNavigateToShipping" class="btn btn-secondary btn-sm">Go to Shipping</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-warning-subtle bg-warning-subtle text-center h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-tags me-2 text-warning"></i>Clearance Items</h5>
                <p class="small text-muted mb-2">@(ViewBag.ClearanceUpsellCount ?? 0) item(s) not moved in 2+ years</p>
                <a asp-controller="Clearance" asp-action="Index" class="btn btn-warning btn-sm fw-semibold">View Clearance</a>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="card stat-card stat-card-green shadow-sm border-0 h-100">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <span class="text-muted small">Pending Orders</span>
                    <i class="bi bi-hourglass-split text-success fs-5"></i>
                </div>
                <p class="fs-3 fw-bold mb-0" style="color:#2d7a4f;">@pendingOrders.Count</p>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card stat-card-blue shadow-sm border-0 h-100">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <span class="text-muted small">Dispatched</span>
                    <i class="bi bi-truck text-primary fs-5"></i>
                </div>
                <p class="fs-3 fw-bold mb-0 text-primary">@dispatchedOrders.Count</p>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card stat-card-orange shadow-sm border-0 h-100">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <span class="text-muted small">Ready for Dispatch</span>
                    <i class="bi bi-box-seam text-warning fs-5"></i>
                </div>
                <p class="fs-3 fw-bold mb-0 text-warning">@readyForDispatchOrders.Count</p>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card stat-card-red shadow-sm border-0 h-100">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <span class="text-muted small">Cancelled Orders</span>
                    <i class="bi bi-exclamation-triangle text-danger fs-5"></i>
                </div>
                <p class="fs-3 fw-bold mb-0 text-danger">@cancelledOrders.Count</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">

    <div class="col-lg-2 d-none d-lg-block">
        <div class="card shadow-sm border-0 custom-sticky-sidebar">
            <div class="card-body p-3">
                <p class="text-uppercase fw-semibold small text-muted mb-2" style="font-size:.7rem;">Quick Nav</p>
                <ul class="nav flex-column sidebar-nav gap-1">
                    <li class="nav-item"><a class="nav-link active" href="#orders"><i class="bi bi-cart3 me-2"></i>Orders</a></li>
                    <li class="nav-item"><a class="nav-link" href="#shipping"><i class="bi bi-truck me-2"></i>Shipping</a></li>
                    <li class="nav-item"><a class="nav-link" href="#inventory"><i class="bi bi-boxes me-2"></i>Inventory</a></li>
                    <li class="nav-item"><a class="nav-link" href="#loans-clearance"><i class="bi bi-box-arrow-up-right me-2"></i>Loans &amp; Clearance</a></li>
                    <li class="nav-item"><a class="nav-link" href="#dispatch"><i class="bi bi-send me-2"></i>Dispatch</a></li>
                    <li class="nav-item"><a class="nav-link" href="#returns"><i class="bi bi-arrow-return-left me-2"></i>Returns</a></li>
                    <li class="nav-item"><a class="nav-link" href="#analytics"><i class="bi bi-bar-chart-line me-2"></i>Analytics</a></li>
                    <li class="nav-item"><a class="nav-link" href="#carbon"><i class="bi bi-leaf me-2"></i>Carbon</a></li>
                </ul>
            </div>
        </div>
    </div>

    <div class="col-lg-10 dashboard-content">

        @await Html.PartialAsync("DashboardPartials/_OrdersPartial")
        @await Html.PartialAsync("_ShippingPartial")
        @await Html.PartialAsync("_InventoryPartial")
        @await Html.PartialAsync("_LoansAndClearancePartial")
        @await Html.PartialAsync("DashboardPartials/_DispatchQueuePartial")
        @await Html.PartialAsync("DashboardPartials/_ReturnsPartial")

        <div id="analytics" class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white border-bottom py-3">
                <h6 class="fw-bold mb-0"><i class="bi bi-bar-chart-line me-2 text-primary"></i>Analytics &amp; Reports</h6>
            </div>
            <div class="card-body">
                @if (ViewBag.AnalyticsWidgets != null && ((IEnumerable<dynamic>)ViewBag.AnalyticsWidgets).Any())
                {
                    <div class="row g-3">
                        @foreach (var widget in ViewBag.AnalyticsWidgets)
                        {
                            <div class="col-md-6 col-xl-4">
                                <div class="border rounded p-3 h-100">
                                    <p class="fw-semibold small mb-1">@widget.Title</p>
                                    <p class="text-muted small mb-2">@widget.Summary</p>
                                    <a href="@widget.ReportUrl" class="btn btn-outline-primary btn-sm w-100">View Report <i class="bi bi-arrow-right ms-1"></i></a>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-3 small"><i class="bi bi-graph-up fs-3 d-block mb-2"></i>No reports available yet.</div>
                }
            </div>
        </div>

        @await Html.PartialAsync("DashboardPartials/_CarbonPartial")

    </div>
</div>

@section Scripts {
<script>
   (function () {
    const sections = ['orders','shipping','inventory','loans-clearance','dispatch','returns','analytics','carbon'];
    const links = sections.reduce((acc, id) => {
        acc[id] = document.querySelector(`.sidebar-nav a[href="#${id}"]`);
        return acc;
    }, {});

    function onScroll() {
        let current = sections[0];
        
        sections.forEach(id => {
            const el = document.getElementById(id);
            // Check if the top of the element has hit our sticky offset (100px + a 50px buffer)
            if (el && el.getBoundingClientRect().top <= 150) { 
                current = id;
            }
        });
        
        sections.forEach(id => { 
            if (links[id]) links[id].classList.toggle('active', id === current); 
        });
    }
    
    window.addEventListener('scroll', onScroll, { passive: true });
    // Run once on load to set initial state
    onScroll();
})();
</script>
}