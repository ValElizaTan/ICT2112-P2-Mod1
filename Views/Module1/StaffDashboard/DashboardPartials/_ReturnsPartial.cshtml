<div id="returns" class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white border-bottom py-3">
        <h6 class="fw-bold mb-0"><i class="bi bi-arrow-repeat me-2 text-primary"></i>Return Pipeline</h6>
        <small class="text-muted">Items moving through return &amp; refurbishment stages</small>
    </div>
    <div class="card-body">
        <div class="row g-3 mb-3">
            @{
                var stages = new[] {
                    ("Inspection", "bi-clipboard-check",   "#6c757d"),
                    ("Repair",     "bi-tools",             "#fd7e14"),
                    ("Servicing",  "bi-wrench-adjustable", "#0d6efd"),
                    ("Cleaning",   "bi-droplet",           "#0a9396"),
                    ("Restocked",  "bi-check-circle",      "#2d7a4f"),
                };
                var stageCounts = ViewBag.StageCounts as Dictionary<string,int> ?? new Dictionary<string,int>();
            }
            @foreach (var (label, icon, color) in stages)
            {
                <div class="col">
                    <div class="text-center p-3 rounded border">
                        <i class="bi @icon fs-4 mb-1" style="color:@color;"></i>
                        <p class="fw-bold mb-0">@(stageCounts.GetValueOrDefault(label, 0))</p>
                        <small class="text-muted" style="font-size:.72rem;">@label</small>
                    </div>
                </div>
            }
        </div>
        <div class="d-flex justify-content-end">
            <a asp-controller="Module2" asp-action="ReturnPipeline" class="btn btn-sm btn-outline-primary">Manage Return Pipeline <i class="bi bi-arrow-right ms-1"></i></a>
        </div>
    </div>
</div>