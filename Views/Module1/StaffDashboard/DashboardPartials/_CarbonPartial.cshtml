<div id="carbon" class="card shadow-sm mb-4" style="background:linear-gradient(135deg,#d1e7dd,#a3cfbb);border:none;">
    <div class="card-body d-flex align-items-center justify-content-between flex-wrap gap-3 py-3">
        <div class="d-flex align-items-center gap-3">
            <i class="bi bi-leaf fs-2" style="color:#2d7a4f;"></i>
            <div>
                <h6 class="fw-bold mb-0">Carbon Footprint</h6>
                <p class="mb-0 small text-muted">This month: <strong>@(ViewBag.CarbonKgCo2 ?? "-") kg CO<sub>2</sub>e</strong> - @(ViewBag.CarbonTrend ?? "No data")</p>
            </div>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="CarbonDashboard" asp-action="StaffView" class="btn btn-success btn-sm fw-semibold"><i class="bi bi-bar-chart-line me-1"></i>Full Carbon Dashboard</a>
            <a asp-controller="CarbonDashboard" asp-action="StaffRouteView" class="btn btn-outline-success btn-sm">Route Impact <i class="bi bi-arrow-right ms-1"></i></a>
        </div>
    </div>
</div>