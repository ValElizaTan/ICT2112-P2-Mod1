@{
    var customer = ViewBag.CustomerInfo;
    var ordersPlaced = ViewBag.OrdersPlaced ?? 0;
    var activeRentals = ViewBag.ActiveRentals ?? 0;
    var completedReturns = ViewBag.CompletedReturns ?? 0;
    var pendingRefunds = ViewBag.PendingRefunds ?? 0;
    var recentActivities = ViewBag.RecentActivities as List<dynamic> ?? new List<dynamic>();
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white border-bottom py-3">
        <h6 class="fw-bold mb-0"><i class="bi bi-activity me-2" style="color:#2d7a4f;"></i>Activity Summary</h6>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-6">
                <div class="border rounded p-3 text-center h-100">
                    <p class="info-label mb-1">Orders Placed</p>
                    <p class="fs-4 fw-bold mb-0" style="color:#2d7a4f;">@ordersPlaced</p>
                </div>
            </div>
            <div class="col-6">
                <div class="border rounded p-3 text-center h-100">
                    <p class="info-label mb-1">Active Rentals</p>
                    <p class="fs-4 fw-bold mb-0" style="color:#0d6efd;">@activeRentals</p>
                </div>
            </div>
            <div class="col-6">
                <div class="border rounded p-3 text-center h-100">
                    <p class="info-label mb-1">Completed Returns</p>
                    <p class="fs-4 fw-bold mb-0 text-warning">@completedReturns</p>
                </div>
            </div>
            <div class="col-6">
                <div class="border rounded p-3 text-center h-100">
                    <p class="info-label mb-1">Pending Refunds</p>
                    <p class="fs-4 fw-bold mb-0 text-danger">@pendingRefunds</p>
                </div>
            </div>
        </div>

        @if (recentActivities != null && recentActivities.Any())
        {
            <hr class="my-3">
            <p class="info-label mb-2">Recent Activities</p>
            <ul class="list-unstyled mb-0">
                @foreach (var activity in recentActivities.Take(5))
                {
                    <li class="d-flex align-items-start gap-2 mb-2">
                        <i class="bi bi-dot fs-5" style="color:#2d7a4f; margin-top:-3px;"></i>
                        <span class="small text-muted">@activity.Description <span style="font-size:.7rem;"
                                                                                       class="ms-1">@activity.Timestamp</span></span>
                        </li>
                    }
                </ul>
            }
        else
            {
                <div class="text-center text-muted py-3 small mt-3">
                    <i class="bi bi-clipboard fs-3 d-block mb-1"></i>No recent activity.
                </div>
            }
        </div>
    </div>

    <style>
        .info-label { font-size: .72rem; text-transform: uppercase; letter-spacing: .04em; color: #6c757d; font-weight: 600; }
    </style>