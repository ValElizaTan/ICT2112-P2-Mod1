@{
    ViewData["Title"] = "Customer Profile";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-3">
            <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left me-1"></i>Back
            </a>
            <h5 class="mb-0 fw-bold">Customer Profile</h5>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["InfoMessage"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @TempData["InfoMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-4">
            @await Html.PartialAsync("CustomerProfileSections/_CustomerIdentityCard")
        </div>
        <div class="col-lg-8">
            @await Html.PartialAsync("CustomerProfileSections/_CustomerEditForm")
            @await Html.PartialAsync("CustomerProfileSections/_CustomerActivitySummary")
        </div>
    </div>
</div>

<style>
    .profile-avatar {
        width: 64px; height: 64px;
        background: rgba(45,122,79,.10);
        color: #2d7a4f;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.6rem; font-weight: 700;
        flex-shrink: 0;
    }
    .info-label { font-size: .72rem; text-transform: uppercase; letter-spacing: .04em; color: #6c757d; font-weight: 600; }
    .info-value { font-size: .92rem; }
    .section-divider { border-left: 3px solid #2d7a4f; }
</style>