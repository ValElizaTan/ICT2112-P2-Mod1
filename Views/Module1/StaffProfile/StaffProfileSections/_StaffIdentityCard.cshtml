@{
    var staff = ViewBag.StaffInfo;
    string initials = staff != null
        ? string.Concat(((string)staff.Name).Split(' ').Take(2).Select(w => w[0].ToString().ToUpper()))
        : "?";
}

<div class="card shadow-sm border-0 h-100">
    <div class="card-body p-4">

        <div class="d-flex align-items-center gap-3 mb-4">
            <div class="profile-avatar">@initials</div>
            <div>
                <p class="fw-bold mb-0">@(staff?.Name ?? "—")</p>
                <span class="badge rounded-pill" style="background:#cfe2ff;color:#084298;font-size:.7rem;">
                    <i class="bi bi-shield-check me-1"></i>Staff
                </span>
            </div>
        </div>

        <hr class="my-3">

        <div class="d-flex flex-column gap-3">
            <div>
                <p class="info-label mb-1">Staff ID</p>
                <p class="info-value mb-0 text-muted">#@(staff?.StaffId ?? "—")</p>
            </div>
            <div>
                <p class="info-label mb-1">Email</p>
                <p class="info-value mb-0">@(staff?.Email ?? "—")</p>
            </div>
            <div>
                <p class="info-label mb-1">Phone</p>
                <p class="info-value mb-0">
                    @if (staff?.PhoneCountry != null && staff?.PhoneNumber != null)
                    {
                        <span>+@staff.PhoneCountry &nbsp;@staff.PhoneNumber</span>
                    }
                    else { <span class="text-muted">—</span> }
                </p>
            </div>
            <div>
                <p class="info-label mb-1">Role</p>
                <p class="info-value mb-0">@(staff?.Role ?? "Staff")</p>
            </div>
        </div>

    </div>
</div>
