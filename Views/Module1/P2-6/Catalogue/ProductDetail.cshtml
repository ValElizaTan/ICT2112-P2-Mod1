@model ProRental.Domain.Module6.Entities.ProductDetailViewModel
@{
    ViewData["Title"] = Model.Product?.GetProductName() ?? "Product Detail";
    var avail  = Model.Availability;
    var carbon = Model.Carbon;
    var p      = Model.Product;
}

@* ── Breadcrumb ───────────────────────────────────────────────────────────── *@
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-controller="Catalogue" asp-action="Index" class="text-decoration-none">
                <i class="bi bi-grid me-1"></i>Catalogue
            </a>
        </li>
        <li class="breadcrumb-item active">@p?.GetProductName()</li>
    </ol>
</nav>

@if (p == null)
{
    <div class="alert alert-warning">Product not found.</div>
}
else
{
    <div class="row g-4">

        @* ── Left: image ──────────────────────────────────────────────────────── *@
        <div class="col-md-5">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden"
                 style="height:380px; background:#f8f9fa;">
                @{
                    var img = p.GetImageUrl();
                }
                @if (!string.IsNullOrWhiteSpace(img))
                {
                    <img src="~/images/products/@img"
                         alt="@p.GetProductName()"
                         class="w-100 h-100 object-fit-cover" />
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center h-100">
                        <i class="bi bi-camera2 display-1 text-muted"></i>
                    </div>
                }
            </div>
        </div>

        @* ── Right: details ───────────────────────────────────────────────────── *@
        <div class="col-md-7">
            <small class="text-muted">
                <i class="bi bi-tag me-1"></i>@p.GetCategoryName()
            </small>
            <h2 class="fw-bold mt-1 mb-2">@p.GetProductName()</h2>

            @* Badges row *@
            <div class="d-flex flex-wrap gap-2 mb-3">
                @if (avail != null)
                {
                    <span class="badge @avail.BadgeClass fs-6 px-3 py-2">
                        <i class="bi bi-box-seam me-1"></i>@avail.Label
                    </span>
                }
                @if (carbon != null)
                {
                    <span class="badge @carbon.BadgeClass fs-6 px-3 py-2">
                        <i class="bi bi-leaf me-1"></i>@carbon.BadgeLabel
                        @if (carbon.TotalCo2Kg > 0)
                        {
                            <span>(@carbon.TotalCo2Kg.ToString("0.0") kg CO₂)</span>
                        }
                    </span>
                }
            </div>

            @* Description *@
            @if (!string.IsNullOrWhiteSpace(p.GetDescription()))
            {
                <p class="text-secondary mb-3">@p.GetDescription()</p>
            }

            @* Specs table *@
            <table class="table table-sm table-borderless mb-3" style="max-width:380px;">
                <tbody>
                    <tr>
                        <th class="text-muted fw-normal small ps-0">SKU</th>
                        <td class="fw-semibold small">@p.GetSku()</td>
                    </tr>
                    <tr>
                        <th class="text-muted fw-normal small ps-0">Weight</th>
                        <td class="fw-semibold small">@(p.GetWeight()?.ToString("0.00") ?? "—") kg</td>
                    </tr>
                    <tr>
                        <th class="text-muted fw-normal small ps-0">Deposit Rate</th>
                        <td class="fw-semibold small">@(p.GetDepositRate()?.ToString("P0") ?? "—")</td>
                    </tr>
                    @if (avail != null)
                    {
                        <tr>
                            <th class="text-muted fw-normal small ps-0">Units Available</th>
                            <td class="fw-semibold small">@avail.AvailableCount</td>
                        </tr>
                    }
                </tbody>
            </table>

            @* Price — FIX (CS0121): GetPrice() is now defined only once in Product.cs *@
            <div class="mb-4">
                <span class="display-6 fw-bold" style="color:#2d7a4f;">
                    $@p.GetPrice().ToString("0.00")
                </span>
                <span class="text-muted fs-5"> / day</span>
            </div>

            @* Add to order form *@
            @if (avail?.IsAvailable == true)
            {
                <form asp-controller="Catalogue" asp-action="AddToOrder" method="post"
                      class="d-flex gap-2 align-items-center">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@p.GetProductId()" />
                    <div style="width:100px;">
                        <input type="number" name="quantity" class="form-control text-center fw-bold"
                               value="1" min="1" max="@avail.AvailableCount" />
                    </div>
                    <button type="submit" class="btn btn-dark px-4">
                        <i class="bi bi-cart-plus me-2"></i>Add to Order
                    </button>
                </form>
            }
            else
            {
                <button class="btn btn-secondary px-4" disabled>
                    <i class="bi bi-slash-circle me-2"></i>Currently Unavailable
                </button>
            }

            @* Back link *@
            <div class="mt-4">
                <a asp-controller="Catalogue" asp-action="Index"
                   class="text-decoration-none text-muted small">
                    <i class="bi bi-arrow-left me-1"></i>Back to Catalogue
                </a>
            </div>
        </div>

    </div>
}
