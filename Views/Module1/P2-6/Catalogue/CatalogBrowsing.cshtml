@model ProRental.Domain.Module6.Entities.CatalogueViewModel
@{
    ViewData["Title"] = "Browse Equipment";
}

@* ── Hero Banner ──────────────────────────────────────────────────────────── *@
<div class="rounded-4 text-white mb-4 p-4 p-md-5"
     style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h1 class="fw-bold mb-1">
                <i class="bi bi-camera2 me-2" style="color:#2d7a4f;"></i>Equipment Catalogue
            </h1>
            <p class="text-white-50 mb-0">
                Browse our full range of professional cameras, lenses, gimbals and accessories.
            </p>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
            <span class="badge bg-success fs-6 px-3 py-2">
                <i class="bi bi-box-seam me-1"></i>@Model.PagedProducts.TotalCount products
            </span>
        </div>
    </div>
</div>

@* ── Feedback Alerts ─────────────────────────────────────────────────────── *@
@if (TempData["AddedItem"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        <strong>@TempData["AddedItem"]</strong> &times; @TempData["AddedQty"] added to your order.
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null || Model.IsError)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@(TempData["Error"] ?? Model.Message)
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* ── Search & Filter Card ─────────────────────────────────────────────────── *@
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3 p-md-4">
        <form asp-controller="Catalogue" asp-action="Index" method="get">
            <div class="row g-2 align-items-end">

                @* Keyword search *@
                <div class="col-12 col-md-4">
                    <label class="form-label small fw-semibold text-muted mb-1">
                        <i class="bi bi-search me-1"></i>Search
                    </label>
                    <input type="text" name="keywords" class="form-control"
                           placeholder="Camera, lens, tripod…"
                           value="@Model.Filter.Keywords" />
                </div>

                @* Category filter *@
                @*
                    FIX (RZ1031): Razor tag helpers do not allow inline C# inside <option> attribute
                    declarations (e.g. @(...) inside selected="..."). Use a plain <select> with
                    Html.Raw to emit the selected attribute, or use a conditional string variable.
                *@
                <div class="col-6 col-md-2">
                    <label class="form-label small fw-semibold text-muted mb-1">
                        <i class="bi bi-tag me-1"></i>Category
                    </label>
                    <select name="categoryId" class="form-select">
                        <option value="">All</option>
                        @foreach (var cat in Model.Categories)
                        {
                            var catSelected = Model.Filter.CategoryId == cat.GetCategoryId() ? "selected" : null;
                            <option value="@cat.GetCategoryId()" selected="@catSelected">@cat.GetName()</option>
                        }
                    </select>
                </div>

                @* Min price *@
                <div class="col-3 col-md-1">
                    <label class="form-label small fw-semibold text-muted mb-1">Min $</label>
                    <input type="number" name="minPrice" class="form-control"
                           placeholder="0" min="0" value="@Model.Filter.MinPrice" />
                </div>

                @* Max price *@
                <div class="col-3 col-md-1">
                    <label class="form-label small fw-semibold text-muted mb-1">Max $</label>
                    <input type="number" name="maxPrice" class="form-control"
                           placeholder="999" min="0" value="@Model.Filter.MaxPrice" />
                </div>

                @* Sort *@
                @*
                    FIX (RZ1031): Same issue as above — pull the selected state into a local
                    variable first, then assign it as selected="@variable".
                *@
                <div class="col-6 col-md-2">
                    <label class="form-label small fw-semibold text-muted mb-1">
                        <i class="bi bi-sort-down me-1"></i>Sort
                    </label>
                    @{
                        var sortBy = Model.Filter.SortBy;
                    }
                    <select name="sortBy" class="form-select">
                        <option value="name_asc"   selected="@(sortBy == "name_asc"   ? "selected" : null)">Name A–Z</option>
                        <option value="name_desc"  selected="@(sortBy == "name_desc"  ? "selected" : null)">Name Z–A</option>
                        <option value="price_asc"  selected="@(sortBy == "price_asc"  ? "selected" : null)">Price ↑</option>
                        <option value="price_desc" selected="@(sortBy == "price_desc" ? "selected" : null)">Price ↓</option>
                    </select>
                </div>

                @* Buttons *@
                <div class="col-6 col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-dark flex-grow-1">
                        <i class="bi bi-funnel-fill me-1"></i>Filter
                    </button>
                    <a asp-controller="Catalogue" asp-action="Index"
                       class="btn btn-outline-secondary" title="Clear filters">
                        <i class="bi bi-x-lg"></i>
                    </a>
                </div>

            </div>
        </form>
    </div>
</div>

@* ── Active filter chips ───────────────────────────────────────────────────── *@
@{
    bool hasFilters = !string.IsNullOrWhiteSpace(Model.Filter.Keywords)
                   || Model.Filter.CategoryId.HasValue
                   || Model.Filter.MinPrice.HasValue
                   || Model.Filter.MaxPrice.HasValue;
}
@if (hasFilters)
{
    <div class="d-flex flex-wrap gap-2 mb-3 align-items-center">
        <small class="text-muted fw-semibold">Active filters:</small>
        @if (!string.IsNullOrWhiteSpace(Model.Filter.Keywords))
        {
            <span class="badge bg-dark rounded-pill">
                <i class="bi bi-search me-1"></i>@Model.Filter.Keywords
            </span>
        }
        @if (Model.Filter.MinPrice.HasValue || Model.Filter.MaxPrice.HasValue)
        {
            <span class="badge bg-dark rounded-pill">
                $@(Model.Filter.MinPrice?.ToString("0") ?? "0") – $@(Model.Filter.MaxPrice?.ToString("0") ?? "∞")
            </span>
        }
        <a asp-controller="Catalogue" asp-action="Index"
           class="badge bg-danger text-decoration-none">
            <i class="bi bi-x me-1"></i>Clear all
        </a>
    </div>
}

@* ── Product Grid ─────────────────────────────────────────────────────────── *@
@if (!Model.PagedProducts.Items.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-search display-3 d-block mb-3" style="color:#2d7a4f;"></i>
        <h5>No products found</h5>
        <p class="small">Try adjusting your search terms or clearing the filters.</p>
        <a asp-controller="Catalogue" asp-action="Index" class="btn btn-outline-dark mt-2">
            <i class="bi bi-arrow-counterclockwise me-1"></i>Reset
        </a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4 mb-4">
        @foreach (var product in Model.PagedProducts.Items)
        {
            var avail  = Model.Availability.GetValueOrDefault(product.GetProductId());
            var carbon = Model.CarbonData.GetValueOrDefault(product.GetProductId());

            <div class="col">
                <div class="card h-100 border-0 shadow-sm product-card">

                    @* Product image *@
                    <div class="position-relative overflow-hidden"
                         style="height:200px; background:#f8f9fa;">
                        @{
                            var img = product.GetImageUrl();
                        }
                        @if (!string.IsNullOrWhiteSpace(img))
                        {
                            <img src="~/images/products/@img" alt="@product.GetProductName()"
                                 class="w-100 h-100 object-fit-cover" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center h-100">
                                <i class="bi bi-camera2 display-4 text-muted"></i>
                            </div>
                        }

                        @* Availability badge – top-right corner *@
                        @if (avail != null)
                        {
                            <span class="badge @avail.BadgeClass position-absolute top-0 end-0 m-2">
                                @avail.Label
                            </span>
                        }
                    </div>

                    <div class="card-body d-flex flex-column">
                        @* Category chip *@
                        <small class="text-muted mb-1">
                            <i class="bi bi-tag me-1"></i>@product.GetCategoryName()
                        </small>

                        <h6 class="card-title fw-bold mb-1">@product.GetProductName()</h6>

                        @if (!string.IsNullOrWhiteSpace(product.GetDescription()))
                        {
                            <p class="card-text text-muted small mb-2"
                               style="overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;">
                                @product.GetDescription()
                            </p>
                        }

                        @* Carbon badge *@
                        @if (carbon != null && carbon.TotalCo2Kg > 0)
                        {
                            <span class="badge @carbon.BadgeClass mb-2" style="width:fit-content;">
                                <i class="bi bi-leaf me-1"></i>@carbon.BadgeLabel
                            </span>
                        }

                        <div class="mt-auto">
                            @* Price — FIX (CS0121): GetPrice() is now defined only once in Product.cs *@
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <span class="fs-5 fw-bold" style="color:#2d7a4f;">
                                    $@product.GetPrice().ToString("0.00")<small class="text-muted fs-6 fw-normal">/day</small>
                                </span>
                                <small class="text-muted">
                                    <i class="bi bi-box-seam me-1"></i>@(avail?.AvailableCount ?? 0) avail.
                                </small>
                            </div>

                            @* Actions *@
                            <div class="d-grid gap-2">
                                <a asp-controller="Catalogue" asp-action="Detail"
                                   asp-route-id="@product.GetProductId()"
                                   class="btn btn-outline-dark btn-sm">
                                    <i class="bi bi-eye me-1"></i>View Details
                                </a>

                                @if (avail?.IsAvailable == true)
                                {
                                    <form asp-controller="Catalogue" asp-action="AddToOrder"
                                          method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@product.GetProductId()" />
                                        <input type="hidden" name="quantity"  value="1" />
                                        <button type="submit" class="btn btn-dark btn-sm w-100">
                                            <i class="bi bi-cart-plus me-1"></i>Add to Order
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <button class="btn btn-secondary btn-sm" disabled>
                                        <i class="bi bi-slash-circle me-1"></i>Unavailable
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @* ── Pagination ────────────────────────────────────────────────────────── *@
    @if (Model.PagedProducts.TotalPages > 1)
    {
        <nav aria-label="Catalogue pagination">
            <ul class="pagination justify-content-center">

                <li class="page-item @(!Model.PagedProducts.HasPrev ? "disabled" : "")">
                    <a class="page-link"
                       asp-controller="Catalogue" asp-action="Index"
                       asp-route-keywords="@Model.Filter.Keywords"
                       asp-route-categoryId="@Model.Filter.CategoryId"
                       asp-route-minPrice="@Model.Filter.MinPrice"
                       asp-route-maxPrice="@Model.Filter.MaxPrice"
                       asp-route-sortBy="@Model.Filter.SortBy"
                       asp-route-page="@(Model.PagedProducts.CurrentPage - 1)">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>

                @for (int i = 1; i <= Model.PagedProducts.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PagedProducts.CurrentPage ? "active" : "")">
                        <a class="page-link @(i == Model.PagedProducts.CurrentPage ? "text-white" : "")"
                           asp-controller="Catalogue" asp-action="Index"
                           asp-route-keywords="@Model.Filter.Keywords"
                           asp-route-categoryId="@Model.Filter.CategoryId"
                           asp-route-minPrice="@Model.Filter.MinPrice"
                           asp-route-maxPrice="@Model.Filter.MaxPrice"
                           asp-route-sortBy="@Model.Filter.SortBy"
                           asp-route-page="@i"
                           style="@(i == Model.PagedProducts.CurrentPage ? "background:#2d7a4f; border-color:#2d7a4f;" : "")">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(!Model.PagedProducts.HasNext ? "disabled" : "")">
                    <a class="page-link"
                       asp-controller="Catalogue" asp-action="Index"
                       asp-route-keywords="@Model.Filter.Keywords"
                       asp-route-categoryId="@Model.Filter.CategoryId"
                       asp-route-minPrice="@Model.Filter.MinPrice"
                       asp-route-maxPrice="@Model.Filter.MaxPrice"
                       asp-route-sortBy="@Model.Filter.SortBy"
                       asp-route-page="@(Model.PagedProducts.CurrentPage + 1)">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>

            </ul>
        </nav>
    }
}

@* ── Card hover style ─────────────────────────────────────────────────────── *@
@section Scripts {
<style>
    .product-card {
        transition: transform .18s ease, box-shadow .18s ease;
    }
    .product-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0,0,0,.12) !important;
    }
</style>
}
