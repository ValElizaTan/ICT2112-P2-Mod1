@model ProRental.Controllers.Module1.MockCheckoutViewModel
@using ProRental.Domain.Enums

@{
    ViewData["Title"] = "Mock Checkout";
}

<h2>Mock Checkout</h2>

<form asp-action="MockCheckout" asp-controller="MockCheckout" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly"></div>

    <div>
        <label asp-for="OrderId"></label>
        <input asp-for="OrderId" />
    </div>

    <div>
        <label asp-for="Amount"></label>
        <input asp-for="Amount" />
    </div>

    <div>
        <label asp-for="Purpose"></label>
        <select asp-for="Purpose">
            @foreach (var purpose in Enum.GetValues(typeof(TransactionPurpose)))
            {
                <option value="@purpose">@purpose</option>
            }
        </select>
    </div>

    <div>
        <label asp-for="NameOnCard"></label>
        <input asp-for="NameOnCard" />
    </div>

    <div>
        <label asp-for="CardNumber"></label>
        <input asp-for="CardNumber" />
    </div>

    <div>
        <label asp-for="ExpirationMonth"></label>
        <input asp-for="ExpirationMonth" />
    </div>

    <div>
        <label asp-for="ExpirationYear"></label>
        <input asp-for="ExpirationYear" />
    </div>

    <div>
        <label asp-for="SecurityCode"></label>
        <input asp-for="SecurityCode" />
    </div>

    <button type="submit">Pay Now</button>
</form>
