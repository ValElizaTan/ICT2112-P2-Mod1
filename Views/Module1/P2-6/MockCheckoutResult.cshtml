@model ProRental.Controllers.Module1.MockCheckoutResultViewModel

@{
    ViewData["Title"] = "Mock Checkout Result";
}

<h2>Payment Submitted</h2>

<p>Order ID: @Model.OrderId</p>
<p>Amount: @Model.Amount</p>
<p>Purpose: @Model.Purpose</p>

<p>Provider: @Model.ProviderName</p>
<p>Provider Transaction ID: @Model.ProviderTransactionId</p>
<p>Status: @Model.Status</p>
<p>Message: @Model.Message</p>

<p>
    <a asp-action="MockCheckout" asp-controller="MockCheckout">Back to Checkout</a>
</p>
