@model ProRental.Domain.Entities.Order
@{
    ViewData["Title"] = "Order Confirmed";
}

<div class="container py-5 text-center" style="max-width:600px;">
    <div class="mb-4">
        <i class="bi bi-check-circle-fill display-1" style="color:#2d7a4f;"></i>
    </div>
    <h2 class="fw-bold mb-2">Order Placed!</h2>
    <p class="text-muted mb-4">
        Your order <strong>#@Model.OrderId</strong> has been received and is
        <span class="badge bg-warning text-dark">@Model.CurrentStatus</span>
    </p>

    <div class="card border-0 shadow-sm text-start mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Order ID</span>
                <strong>#@Model.OrderId</strong>
            </div>
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Order Date</span>
                <span>@Model.OrderDate.ToString("dd MMM yyyy, HH:mm")</span>
            </div>
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Delivery Type</span>
                <span>@Model.DeliveryDurationType?.ToString().Replace("_", " ")</span>
            </div>
            <hr />
            <div class="d-flex justify-content-between fw-bold">
                <span>Total Charged</span>
                <span style="color:#2d7a4f;">@Model.TotalAmount.ToString("C")</span>
            </div>
        </div>
    </div>

    <div class="d-grid gap-2">
        <a asp-controller="Catalogue" asp-action="Index" class="btn btn-dark">
            <i class="bi bi-arrow-left me-1"></i>Continue Browsing
        </a>
    </div>
</div>