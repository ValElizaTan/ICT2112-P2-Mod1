@using System.Collections
@using System.Reflection

@{
    ViewData["Title"] = "Cart";

    var items = ViewBag.Items as IEnumerable;
    var summary = ViewBag.Summary;

    decimal totalItemCost = 0m;
    if (summary != null)
    {
        var totalProp = summary.GetType().GetProperty("TotalItemCost")
                     ?? summary.GetType().GetProperty("TotalCost")
                     ?? summary.GetType().GetProperty("RentalCost");

        if (totalProp != null)
        {
            var raw = totalProp.GetValue(summary);
            if (raw != null) totalItemCost = Convert.ToDecimal(raw);
        }
    }

    string rentalStart = ViewBag.RentalStart ?? DateTime.Today.ToString("yyyy-MM-dd");
    string rentalEnd = ViewBag.RentalEnd ?? DateTime.Today.ToString("yyyy-MM-dd");
}

<h1 class="mb-4">Cart</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}

<div class="card mb-4">
    <div class="card-body">
        <h3 class="h4 mb-3">Rental Period</h3>

        <form asp-action="SetRentalPeriod" method="post">
            @Html.AntiForgeryToken()

            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label for="start" class="form-label">Start</label>
                    <input type="date"
                           id="start"
                           name="start"
                           class="form-control"
                           value="@rentalStart" />
                </div>

                <div class="col-md-4">
                    <label for="end" class="form-label">End</label>
                    <input type="date"
                           id="end"
                           name="end"
                           class="form-control"
                           value="@rentalEnd" />
                </div>

                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary">
                        Set Rental Period
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="mb-3 d-flex gap-2 flex-wrap">
    <form asp-action="SelectAll" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-success">Select All</button>
    </form>

    <form asp-action="ClearSelection" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-secondary">Clear Selection</button>
    </form>

    <form asp-action="EmptyCart" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-danger">Empty Cart</button>
    </form>
</div>

@if (items == null || !items.Cast<object>().Any())
{
    <div class="alert alert-warning">
        Your cart is empty. Browse the catalogue to add items.
    </div>
}
else
{
    <div class="card mb-4">
        <div class="card-body">
            <h3 class="h4 mb-3">Cart Items</h3>

            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Select</th>
                            <th>Product</th>
                            <th>Quantity</th>
                            <th>Price</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in items)
                    {
                        var itemType = item.GetType();

                        int productId = 0;
                        int qty = 0;
                        bool isSelected = false;
                        string productName = "";
                        decimal price = 0m;

                        decimal subtotal = 0m;

                        var subtotalProp = itemType.GetProperty("Subtotal");
                        if (subtotalProp != null)
                        {
                            var raw = subtotalProp.GetValue(item);
                            if (raw != null) subtotal = Convert.ToDecimal(raw);
                        }

                        var productIdProp = itemType.GetProperty("ProductId");
                        if (productIdProp != null)
                        {
                            var raw = productIdProp.GetValue(item);
                            if (raw != null) productId = Convert.ToInt32(raw);
                        }

                        var qtyProp = itemType.GetProperty("Quantity");
                        if (qtyProp != null)
                        {
                            var raw = qtyProp.GetValue(item);
                            if (raw != null) qty = Convert.ToInt32(raw);
                        }

                        var selectedProp = itemType.GetProperty("IsSelected");
                        if (selectedProp != null)
                        {
                            var raw = selectedProp.GetValue(item);
                            if (raw != null) isSelected = Convert.ToBoolean(raw);
                        }

                        var nameProp = itemType.GetProperty("ProductName")
                                   ?? itemType.GetProperty("Name");
                        if (nameProp != null)
                        {
                            productName = nameProp.GetValue(item)?.ToString() ?? "";
                        }

                        var priceProp = itemType.GetProperty("CartItemPrice")
                                            ?? itemType.GetProperty("LineTotal")
                                            ?? itemType.GetProperty("ItemCost")
                                            ?? itemType.GetProperty("Cost")
                                            ?? itemType.GetProperty("Price");
                        if (priceProp != null)
                        {
                            var raw = priceProp.GetValue(item);
                            if (raw != null) price = Convert.ToDecimal(raw);
                        }

                        <tr>
                            <td>
                                <form asp-action="ToggleSelectItem" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@productId" />
                                    <input type="hidden" name="isSelected" value="@(isSelected ? "false" : "true")" />
                                    <button type="submit" class="btn btn-sm @(isSelected ? "btn-success" : "btn-outline-secondary")">
                                        @(isSelected ? "Selected" : "Select")
                                    </button>
                                </form>
                            </td>

                            <td>@productName</td>

                            <td style="min-width: 220px;">
                                <form asp-action="UpdateQuantity" method="post" class="d-flex gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@productId" />
                                    <input type="number" name="qty" value="@qty" min="1" class="form-control form-control-sm" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary">Update</button>
                                </form>
                            </td>

                            <td>@price.ToString("0.00")</td>

                            <td>
                                <form asp-action="RemoveItem" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@productId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<div class="card mb-4">
    <div class="card-body">
        <h3 class="h4 mb-3">Cost Summary</h3>
        <p class="mb-0">
            <strong>Total Item Cost:</strong> @totalItemCost.ToString("0.00")
        </p>
    </div>
</div>

<form asp-action="StartCheckout" method="post">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-success btn-lg">Start Checkout</button>
</form>