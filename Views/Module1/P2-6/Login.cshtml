@{
    ViewData["Title"] = "Sign In";
    var activeTab = ViewBag.ActiveTab as string ?? "customer";
}

<div class="row justify-content-center py-5">
    <div class="col-12 col-sm-10 col-md-7 col-lg-5">

        <!-- Page heading -->
        <div class="text-center mb-4">
            <span class="bi bi-box-arrow-in-right fs-1 text-primary"></span>
            <h1 class="h3 mt-2 fw-semibold">Sign in to ProRental</h1>
            <p class="text-muted">Welcome back — enter your credentials below.</p>
        </div>

        <!-- Alerts -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success d-flex align-items-center gap-2 py-2" role="alert">
                <i class="bi bi-check-circle-fill flex-shrink-0"></i>
                <span class="small">@TempData["SuccessMessage"]</span>
            </div>
        }

        <!-- Tab toggle -->
        <ul class="nav nav-pills nav-fill mb-3" id="loginTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "customer" ? "active" : "")"
                        id="customer-tab"
                        data-bs-toggle="pill"
                        data-bs-target="#customer-pane"
                        type="button"
                        role="tab"
                        aria-controls="customer-pane"
                        aria-selected="@(activeTab == "customer" ? "true" : "false")">
                    <i class="bi bi-person me-1"></i>Customer
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "staff" ? "active" : "")"
                        id="staff-tab"
                        data-bs-toggle="pill"
                        data-bs-target="#staff-pane"
                        type="button"
                        role="tab"
                        aria-controls="staff-pane"
                        aria-selected="@(activeTab == "staff" ? "true" : "false")">
                    <i class="bi bi-shield-lock me-1"></i>Staff / Admin
                </button>
            </li>
        </ul>

        <div class="tab-content">

            <!-- ── Customer login pane ── -->
            <div class="tab-pane fade @(activeTab == "customer" ? "show active" : "")"
                 id="customer-pane"
                 role="tabpanel"
                 aria-labelledby="customer-tab">

                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">

                        @if (activeTab == "customer" && !ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-3" role="alert">
                                <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
                                <div asp-validation-summary="All" class="small mb-0"></div>
                            </div>
                        }

                        <form asp-action="Login" method="post">
                            @Html.AntiForgeryToken()

                            <!-- Email -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold" for="Email">
                                    <i class="bi bi-envelope me-1 text-primary"></i>Email address
                                </label>
                                <input type="email"
                                       id="Email"
                                       name="Email"
                                       class="form-control"
                                       placeholder="you@example.com"
                                       autocomplete="email"
                                       required />
                            </div>

                            <!-- Password -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold" for="Password">
                                    <i class="bi bi-lock me-1 text-primary"></i>Password
                                </label>
                                <input type="password"
                                       id="Password"
                                       name="Password"
                                       class="form-control"
                                       placeholder="••••••••"
                                       autocomplete="current-password"
                                       required />
                            </div>

                            <!-- Remember me + Forgot password -->
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           id="RememberMe"
                                           name="RememberMe" />
                                    <label class="form-check-label text-muted small" for="RememberMe">
                                        Remember me
                                    </label>
                                </div>
                                <a asp-action="ForgotPassword" class="small">Forgot password?</a>
                            </div>

                            <!-- Submit -->
                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                                </button>
                            </div>
                        </form>

                    </div>
                </div>

                <hr class="my-4" />

                <p class="text-center text-muted small">
                    Don't have an account?
                    <a asp-action="Signup" class="fw-semibold">Create one free</a>
                </p>

            </div>

            <!-- ── Staff login pane ── -->
            <div class="tab-pane fade @(activeTab == "staff" ? "show active" : "")"
                 id="staff-pane"
                 role="tabpanel"
                 aria-labelledby="staff-tab">

                <!-- Restricted access badge -->
                <div class="text-center mb-3">
                    <span class="badge bg-warning text-dark px-3 py-2">
                        <i class="bi bi-shield-lock-fill me-1"></i>Restricted Access
                    </span>
                    <p class="text-muted small mt-2 mb-0">Authorised personnel only. All sessions are logged and audited.</p>
                </div>

                <div class="card shadow-sm border-warning border-opacity-50">
                    <div class="card-body p-4">

                        @if (activeTab == "staff" && !ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-3" role="alert">
                                <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
                                <div asp-validation-summary="All" class="small mb-0"></div>
                            </div>
                        }

                        <form asp-action="StaffLogin" method="post">
                            @Html.AntiForgeryToken()

                            <!-- Staff ID / Email -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold" for="StaffEmail">
                                    <i class="bi bi-person-badge me-1 text-warning"></i>Staff ID / Email
                                </label>
                                <input type="email"
                                       id="StaffEmail"
                                       name="StaffEmail"
                                       class="form-control"
                                       placeholder="staff@prorentals.sg"
                                       autocomplete="email"
                                       required />
                            </div>

                            <!-- Password -->
                            <div class="mb-4">
                                <label class="form-label fw-semibold" for="StaffPassword">
                                    <i class="bi bi-lock me-1 text-warning"></i>Password
                                </label>
                                <input type="password"
                                       id="StaffPassword"
                                       name="StaffPassword"
                                       class="form-control"
                                       placeholder="••••••••"
                                       autocomplete="current-password"
                                       required />
                            </div>

                            <!-- Submit -->
                            <div class="d-grid">
                                <button type="submit" class="btn btn-warning btn-lg text-dark fw-semibold">
                                    <i class="bi bi-box-arrow-in-right me-2"></i>Staff Login
                                </button>
                            </div>
                        </form>

                    </div>
                </div>

                <!-- Security notice -->
                <div class="alert alert-dark d-flex align-items-start gap-2 mt-4 py-3" role="alert">
                    <i class="bi bi-info-circle-fill flex-shrink-0 mt-1 text-warning"></i>
                    <div class="small">
                        Unauthorised access attempts are monitored and may result in legal action.
                        If you are not staff, use the
                        <a href="#" class="alert-link" onclick="document.getElementById('customer-tab').click(); return false;">customer login</a> instead.
                    </div>
                </div>

            </div>

        </div>

    </div>
</div>
