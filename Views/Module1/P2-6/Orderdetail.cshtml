@model ProRental.Domain.Entities.Order
@using ProRental.Domain.Enums

@{
    ViewData["Title"] = $"Order #{Model.OrderId}";

    var allStatuses = new[] {
        OrderStatus.PENDING, OrderStatus.CONFIRMED, OrderStatus.PROCESSING,
        OrderStatus.READY_FOR_DISPATCH, OrderStatus.DISPATCHED, OrderStatus.DELIVERED
    };

    int currentIndex = Array.IndexOf(allStatuses, Model.CurrentStatus ?? OrderStatus.PENDING);

    bool IsCancellable = Model.CurrentStatus == OrderStatus.PENDING ||
                         Model.CurrentStatus == OrderStatus.CONFIRMED;
}

<style>
    .detail-page { background: #f5f5f5; min-height: 100vh; padding: 24px 0; }
    .detail-container { max-width: 820px; margin: 0 auto; padding: 0 16px; }

    .back-link {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 13px; color: #2d7a4f; text-decoration: none;
        margin-bottom: 16px; font-weight: 600;
    }
    .back-link:hover { color: #245f3e; }

    .section-card {
        background: white;
        border-radius: 8px;
        box-shadow: 0 1px 4px rgba(0,0,0,0.08);
        margin-bottom: 14px;
        overflow: hidden;
    }
    .section-header {
        padding: 14px 20px;
        border-bottom: 1px solid #f5f5f5;
        font-size: 13px;
        font-weight: 700;
        color: #333;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    /* Status progress bar */
    .progress-track {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 28px 32px;
        position: relative;
    }
    .progress-track::before {
        content: '';
        position: absolute;
        top: 42px;
        left: 60px; right: 60px;
        height: 3px;
        background: #e8e8e8;
        z-index: 0;
    }
    .progress-fill {
        position: absolute;
        top: 42px;
        left: 60px;
        height: 3px;
        background: #2d7a4f;
        z-index: 1;
        transition: width 0.5s ease;
    }
    .progress-step { display: flex; flex-direction: column; align-items: center; gap: 8px; z-index: 2; flex: 1; }
    .step-dot {
        width: 28px; height: 28px;
        border-radius: 50%;
        background: #e8e8e8;
        display: flex; align-items: center; justify-content: center;
        font-size: 13px;
        border: 3px solid white;
        box-shadow: 0 0 0 2px #e8e8e8;
    }
    .step-dot.done { background: #2d7a4f; box-shadow: 0 0 0 2px #2d7a4f; color: white; }
    .step-dot.current { background: #2d7a4f; box-shadow: 0 0 0 3px #a8d8b8; color: white; }
    .step-label { font-size: 11px; text-align: center; color: #aaa; font-weight: 500; max-width: 72px; }
    .step-label.done, .step-label.current { color: #2d7a4f; font-weight: 700; }

    /* Cancelled state */
    .cancelled-banner {
        padding: 20px;
        background: #fff5f5;
        border-left: 4px solid #e53935;
        margin: 16px 20px;
        border-radius: 4px;
        font-size: 14px;
        color: #c62828;
        font-weight: 600;
    }

    /* Items */
    .item-row {
        display: flex; align-items: center; gap: 14px;
        padding: 16px 20px;
        border-bottom: 1px solid #f5f5f5;
    }
    .item-row:last-child { border-bottom: none; }
    .item-icon {
        width: 56px; height: 56px; background: #f0f7f4;
        border-radius: 6px; display: flex; align-items: center;
        justify-content: center; font-size: 24px; flex-shrink: 0;
    }
    .item-info { flex: 1; }
    .item-name { font-size: 14px; font-weight: 600; color: #333; }
    .item-meta { font-size: 12px; color: #999; margin-top: 3px; }
    .rental-dates { font-size: 11px; color: #aaa; margin-top: 2px; }
    .item-price { font-size: 15px; font-weight: 800; color: #2d7a4f; }

    /* Cost breakdown */
    .cost-row {
        display: flex; justify-content: space-between;
        padding: 10px 20px; font-size: 13px; color: #666;
        border-bottom: 1px solid #f5f5f5;
    }
    .cost-row:last-child { border-bottom: none; }
    .cost-row.total { font-size: 16px; font-weight: 800; color: #333; padding: 14px 20px; }
    .cost-row.total span:last-child { color: #2d7a4f; font-size: 20px; }

    /* Status history timeline */
    .history-list { padding: 16px 20px; }
    .history-item { display: flex; gap: 14px; margin-bottom: 14px; }
    .history-item:last-child { margin-bottom: 0; }
    .history-dot {
        width: 10px; height: 10px; border-radius: 50%;
        background: #2d7a4f; flex-shrink: 0; margin-top: 4px;
    }
    .history-status { font-size: 13px; font-weight: 700; color: #333; }
    .history-time { font-size: 11px; color: #aaa; margin-top: 2px; }
    .history-remark { font-size: 12px; color: #888; margin-top: 2px; }

    /* Actions */
    .actions-bar {
        display: flex; gap: 10px; justify-content: flex-end;
        padding: 16px 20px;
    }
    .btn-back {
        background: white; border: 1px solid #ddd; color: #666;
        padding: 9px 20px; border-radius: 4px; font-size: 13px;
        font-weight: 600; text-decoration: none; transition: all 0.2s;
    }
    .btn-back:hover { border-color: #999; color: #333; }
    .btn-cancel-order {
        background: white; border: 1px solid #e53935; color: #e53935;
        padding: 9px 20px; border-radius: 4px; font-size: 13px;
        font-weight: 700; cursor: pointer; transition: all 0.2s;
    }
    .btn-cancel-order:hover { background: #e53935; color: white; }

    .order-id-tag { font-size: 12px; color: #999; font-weight: 400; }
</style>

<div class="detail-page">
    <div class="detail-container">

        <a href="javascript:history.back()" class="back-link">← Back to Orders</a>

        <!-- Status Progress -->
        <div class="section-card">
            <div class="section-header">
                <span>Order #@Model.OrderId <span class="order-id-tag">· @Model.OrderDate.ToString("dd MMM yyyy HH:mm")</span></span>
                <span>Delivery: @Model.DeliveryDurationType</span>
            </div>

            @if (Model.CurrentStatus == OrderStatus.CANCELLED)
            {
                <div class="cancelled-banner">✕ This order has been cancelled.</div>
            }
            else
            {
                var fillPct = currentIndex <= 0 ? 0 : (currentIndex * 100 / (allStatuses.Length - 1));
                <div class="progress-track">
                    <div class="progress-fill" style="width: calc(@fillPct% - 0px);"></div>
                    @for (int i = 0; i < allStatuses.Length; i++)
                    {
                        var s = allStatuses[i];
                        var cls = i < currentIndex ? "done" : (i == currentIndex ? "current" : "");
                        var icon = i < currentIndex ? "✓" : (i == currentIndex ? "●" : "○");
                        var labels = new[] { "Placed", "Confirmed", "Processing", "Ready", "Dispatched", "Delivered" };
                        <div class="progress-step">
                            <div class="step-dot @cls">@(i < currentIndex ? "✓" : "")</div>
                            <div class="step-label @cls">@labels[i]</div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Items -->
        <div class="section-card">
            <div class="section-header">Items Ordered</div>
            @foreach (var item in Model.Orderitems)
            {
                <div class="item-row">
                    <div class="item-icon">📷</div>
                    <div class="item-info">
                        <div class="item-name">Product #@item.ProductId</div>
                        <div class="item-meta">Quantity: @item.OrderedQuantity</div>
                        @if (item.RentalStart.HasValue)
                        {
                            <div class="rental-dates">
                                Rental: @item.RentalStart.Value.ToString("dd MMM yyyy") – @item.RentalEnd?.ToString("dd MMM yyyy")
                            </div>
                        }
                    </div>
                    <div class="item-price">$@item.UnitPrice.ToString("F2")</div>
                </div>
            }
        </div>

        <!-- Cost Breakdown -->
        <div class="section-card">
            <div class="section-header">Payment Summary</div>
            <div class="cost-row"><span>Subtotal (@Model.Orderitems.Count items)</span><span>$@Model.Orderitems.Sum(i => i.UnitPrice).ToString("F2")</span></div>
            <div class="cost-row"><span>Delivery Fee</span><span>$0.00</span></div>
            <div class="cost-row total"><span>Order Total</span><span>$@Model.TotalAmount.ToString("F2")</span></div>
        </div>

        <!-- Status History -->
        @if (Model.Orderstatushistories.Any())
        {
            <div class="section-card">
                <div class="section-header">Status History</div>
                <div class="history-list">
                    @foreach (var h in Model.Orderstatushistories.OrderByDescending(h => h.OccurredAt))
                    {
                        <div class="history-item">
                            <div class="history-dot"></div>
                            <div>
                                <div class="history-status">@h.UpdatedBy</div>
                                <div class="history-time">@h.OccurredAt.ToString("dd MMM yyyy HH:mm") · @h.UpdatedBy</div>
                                @if (!string.IsNullOrEmpty(h.StatusRemark))
                                {
                                    <div class="history-remark">@h.StatusRemark</div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Actions -->
        <div class="section-card">
            <div class="actions-bar">
                <a href="/Module1/Orders?customerId=@Model.CustomerId" class="btn-back">Back to Orders</a>
                @if (IsCancellable)
                {
                    <form method="post" action="/Module1/CancelOrder" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="orderId" value="@Model.OrderId" />
                        <input type="hidden" name="customerId" value="@Model.CustomerId" />
                        <button type="submit" class="btn-cancel-order"
                            onclick="return confirm('Are you sure you want to cancel order #@Model.OrderId?')">
                            Cancel Order
                        </button>
                    </form>
                }
            </div>
        </div>

    </div>
</div>
