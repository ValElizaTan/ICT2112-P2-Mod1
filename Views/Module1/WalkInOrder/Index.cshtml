@{
    ViewData["Title"] = "Walk-In Order";
}

<h2>Walk-In Order</h2>

<div class="walk-in-order">
    <ul class="steps">
        <li>Enter Customer Details</li>
        <li>Select Products</li>
        <li>Review Order</li>
        <li>Confirm Order</li>
    </ul>

    <a asp-action="EnterCustomerDetails" class="btn btn-primary">Start Walk-In Order</a>
</div>
