<div class="card shadow-sm border-0">
    <div class="card-header bg-white border-bottom py-3">
        <h6 class="fw-bold mb-0"><i class="bi bi-activity me-2 text-primary"></i>Activity Summary</h6>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-6">
                <div class="border rounded p-3 text-center h-100">
                    <p class="info-label mb-1">Orders Handled</p>
                    <p class="fs-4 fw-bold mb-0" style="color:#0d6efd;">@(ViewBag.OrdersHandled ?? 0)</p>
                </div>
            </div>
            <div class="col-6">
                <div class="border rounded p-3 text-center h-100">
                    <p class="info-label mb-1">Dispatches</p>
                    <p class="fs-4 fw-bold mb-0" style="color:#2d7a4f;">@(ViewBag.DispatchCount ?? 0)</p>
                </div>
            </div>
            <div class="col-6">
                <div class="border rounded p-3 text-center h-100">
                    <p class="info-label mb-1">Returns Processed</p>
                    <p class="fs-4 fw-bold mb-0 text-warning">@(ViewBag.ReturnsProcessed ?? 0)</p>
                </div>
            </div>
            <div class="col-6">
                <div class="border rounded p-3 text-center h-100">
                    <p class="info-label mb-1">Overdue Flagged</p>
                    <p class="fs-4 fw-bold mb-0 text-danger">@(ViewBag.OverdueFlagged ?? 0)</p>
                </div>
            </div>
        </div>

        @if (ViewBag.RecentActions != null && ((IEnumerable<dynamic>)ViewBag.RecentActions).Any())
        {
            <hr class="my-3">
            <p class="info-label mb-2">Recent Actions</p>
            <ul class="list-unstyled mb-0">
                @foreach (var action in ((IEnumerable<dynamic>)ViewBag.RecentActions).Take(5))
                {
                    <li class="d-flex align-items-start gap-2 mb-2">
                        <i class="bi bi-dot fs-5 text-primary flex-shrink-0" style="margin-top:-3px;"></i>
                        <span class="small text-muted">@action.Description <span style="font-size:.7rem;" class="ms-1">@action.Timestamp.ToString("d MMM HH:mm")</span></span>
                    </li>
                }
            </ul>
        }
        else
        {
            <div class="text-center text-muted py-3 small mt-3">
                <i class="bi bi-clipboard fs-3 d-block mb-1"></i>No recent activity.
            </div>
        }
    </div>
</div>
