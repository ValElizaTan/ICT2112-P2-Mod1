<div id="dispatch" class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white border-bottom py-3">
        <h6 class="fw-bold mb-0"><i class="bi bi-send me-2" style="color:#fd7e14;"></i>Dispatch Queue</h6>
        <small class="text-muted">Orders awaiting pickup or courier assignment</small>
    </div>
    <div class="card-body">
        @if (ViewBag.DispatchQueue != null && ((IEnumerable<dynamic>)ViewBag.DispatchQueue).Any())
        {
            <div class="row g-3">
                @foreach (var dq in ViewBag.DispatchQueue)
                {
                    <div class="col-md-6 col-xl-4">
                        <div class="card border border-warning-subtle h-100">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <span class="fw-bold small">#@dq.OrderId</span>
                                    <span class="badge badge-ready rounded-pill badge-xs">Ready</span>
                                </div>
                                <p class="mb-1 small text-muted"><i class="bi bi-person me-1"></i>@dq.CustomerName</p>
                                <p class="mb-1 small text-muted"><i class="bi bi-geo-alt me-1"></i>@dq.DeliveryAddress</p>
                                <p class="mb-3 small text-muted"><i class="bi bi-calendar me-1"></i>Deliver by @dq.TargetDate.ToString("d MMM yy")</p>
                                <a asp-controller="Module1" asp-action="AssignDispatch" asp-route-id="@dq.OrderId" class="btn btn-warning btn-sm w-100 fw-semibold">
                                    <i class="bi bi-truck me-1"></i>Assign Courier
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center text-muted py-3 small">
                <i class="bi bi-check2-circle fs-3 d-block mb-2 text-success"></i>
                Dispatch queue is clear - no orders pending assignment.
            </div>
        }
    </div>
</div>